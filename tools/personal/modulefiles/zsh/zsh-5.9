#%Module1.0
##
## zsh modulefiles
##
proc ModulesHelp { } {
    puts stderr "This module loads zsh $version into the environment"
}

module-whatis "Loads zsh 5.9 and updates PATH and other environment variables"

set base $env(OMW_HOME)/tools/personal/software
set appname zsh
set version 5.9
set prefix ${base}/${appname}/${appname}-${version}
set zsh_bin ${prefix}/bin/zsh

setenv ZDOTDIR $env(CONFIG_PATH)/${appname}/${appname}-${version}
setenv HISTFILE $env(CONFIG_PATH)/${appname}/${appname}-${version}/.zsh_history

module load ncurses/ncurses-6.5

prepend-path PATH                   $prefix/bin
#prepend-path C_INCLUDE_PATH        $prefix/include
#prepend-path CPLUS_INCLUDE_PATH    $prefix/include
prepend-path LIBRARY_PATH           $prefix/lib
prepend-path LD_LIBRARY_PATH        $prefix/lib
#prepend-path PKG_CONFIG_PATH       $prefix/lib/pkgconfig
prepend-path MANPATH                $prefix/share/man

