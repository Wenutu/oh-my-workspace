#%Module1.0
##
## lua modulefiles
##
proc ModulesHelp { } {
    puts stderr "This module loads lua $version into the environment"
}

module-whatis "Loads lua 5.4.7 and updates PATH and other environment variables"

set base $env(OMW_HOME)/tools/public/software
set appname lua
set version 5.4.7
set prefix ${base}/${appname}/${appname}-${version}

prepend-path PATH               $prefix/bin
prepend-path C_INCLUDE_PATH     $prefix/include
prepend-path CPLUS_INCLUDE_PATH $prefix/include
prepend-path LIBRARY_PATH       $prefix/lib
prepend-path LD_LIBRARY_PATH    $prefix/lib
prepend-path PKG_CONFIG_PATH    $prefix/lib/pkgconfig
prepend-path MANPATH            $prefix/share/man





