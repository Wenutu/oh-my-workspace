#%Module1.0
##
## local modulefiles
##
proc ModulesHelp { } {
    puts stderr "This module loads local $version into the environment"
}

module-whatis "Loads local 1.0.0 and updates PATH and other environment variables"

set base $env(OMW_HOME)/tools/public/software
set appname local
set version 1.0.0
set prefix ${base}/${appname}/${appname}-${version}

if {[info exists env(CFLAGS)]} {
    setenv CFLAGS "$env(CFLAGS) -I$prefix/usr/include -I/usr/include"
} else {
    setenv CFLAGS "-I$prefix/usr/include -I/usr/include"
}

if {[info exists env(LDFLAGS)]} {
    setenv LDFLAGS "$env(LDFLAGS) -L$prefix/usr/lib64 -L/usr/lib64"
} else {
    setenv LDFLAGS "-L$prefix/usr/lib64 -L/usr/lib64"
}

set local_prefix $prefix/usr
prepend-path PATH               $local_prefix/bin
prepend-path C_INCLUDE_PATH     $local_prefix/include
prepend-path CPLUS_INCLUDE_PATH $local_prefix/include
prepend-path LIBRARY_PATH       $local_prefix/lib64
prepend-path LD_LIBRARY_PATH    $local_prefix/lib64
prepend-path PKG_CONFIG_PATH    $local_prefix/lib64/pkgconfig
prepend-path PKG_CONFIG_PATH    $local_prefix/share/pkgconfig
prepend-path MANPATH            $local_prefix/share/man



