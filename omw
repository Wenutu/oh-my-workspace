# Build local dependencies using system packages
build_local() {
    local force=${1:-false}
    local version=${PUBLIC_SOFTWARE[local]}
    local prefix="$PUBLIC_SOFTWARE_PATH/local/local-$version"
    local build_dir="$PUBLIC_SOFTWARE_PATH/local/build"
    local package_path="$PACKAGES_PATH/rpms.tar.gz"

    log "###############################################################################"
    log "# Building local dependencies $version"
    log "###############################################################################"

    [[ "$force" == "force" ]] && rm -rf "$prefix" "$build_dir"

    if [[ -d "$prefix" ]]; then
        log "Local dependencies already installed" "INFO"
        return 0
    fi
    if [[ ! -d "$build_dir" ]]; then
        mkdir -p "$build_dir"
    fi
    # build is empty download required packages
    if [[ ! -f $package_path ]] && [[ -z "$(ls -A $build_dir)" ]]; then
        log "Downloading system dependencies..." "INFO"
        # Download required RPM packages
        spinner &
        spinner_pid=$!
        yumdownloader --destdir="$build_dir" --resolve \
            gtk3-devel \
            libX11-devel \
            libXt-devel \
            libSM-devel \
            libICE-devel \
            libXpm-devel \
            xorg-x11-proto-devel \
            perl-ExtUtils-Embed > /dev/null
        kill "$spinner_pid" 2>/dev/null
        stop_spinner

        # Remove 32-bit packages
        find "$build_dir" -name "*.i686.rpm" -delete
    else
        extract_package "$package_path" "$build_dir"
    fi
    
    mkdir -p "$prefix"
    cd $prefix
    log "Extracting packages to $prefix..." "INFO"
    find $build_dir -maxdepth 1 -name "*.rpm" -print0 | while IFS= read -r -d $'\0' rpm_file; do
        rpm2cpio "$rpm_file" | cpio -idmv &> /dev/null
    done

    # Fix broken symbolic links
    log "Fixing symbolic links..." "INFO"
    find "$prefix" -type l | while read -r link; do
        target=$(readlink "$link")
        if [[ ! -e "$prefix/$target" ]]; then
            new_target="/lib64/$target"
            if [[ -e "$new_target" ]]; then
                ln -sfn "$new_target" "$link"
                #log "Fixed link: $link -> $new_target" "DEBUG"
            fi
        fi
    done

    # Fix .pc files
    log "Updating pkg-config files..." "INFO"
    find "$prefix" -name "*.pc" | while read -r pcfile; do
        sed -i "s|=/usr|=$prefix/usr|g" $pcfile
        sed -i "s|-I/usr|-I$prefix/usr|g" "$pcfile"
        sed -i "s|-L/usr|-L$prefix/usr|g" "$pcfile"
    done

    local modulefile_path=$(write_modulefile local "$version" public "-I\$prefix/include -I/usr/include" "-L\$prefix/lib -L/usr/lib64")
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created: $modulefile_path" "INFO"
        sed -i "s|set prefix  \$base/\$name/\$name-\$version|set prefix  \$base/\$name/\$name-\$version/usr|g" "$modulefile_path"
        sed -i "s|\$prefix/lib|\$prefix/lib64|g" "$modulefile_path"
        echo "prepend-path PKG_CONFIG_PATH    \$prefix/share/pkgconfig" >> "$modulefile_path"
    else
        log "Failed to create modulefile for local" "ERROR"
    fi
    log "Local dependencies installed successfully" "SUCCESS"
}

# Build Python with optimized settings
build_python() {
    local force=${1:-false}
    local version=${PERSONAL_SOFTWARE[python]}
    local prefix="$PERSONAL_SOFTWARE_PATH/python/python-$version"
    local pkg_url="https://www.python.org/ftp/python/$version/Python-$version.tgz"
    local pkg_path="$PACKAGES_PATH/software/Python-$version.tgz"
    local build_dir="$PERSONAL_SOFTWARE_PATH/python/build"

    log "###############################################################################"
    log "# Building Python $version"
    log "###############################################################################"

    [[ "$force" == "force" ]] && rm -rf "$prefix" "$build_dir"

    if [[ -d "$prefix" ]]; then
        log "Python $version already installed" "INFO"
        return 0
    fi

    download_package "$pkg_url" "$pkg_path"
    extract_package "$pkg_path" "$build_dir"

    # Load required modules
    build_openssl
    module load openssl/openssl-${PUBLIC_SOFTWARE[openssl]}
    local configure_command="./configure --prefix=$prefix --with-openssl=$PUBLIC_SOFTWARE_PATH/openssl/openssl-${PUBLIC_SOFTWARE[openssl]} --with-ensurepip=install --enable-shared"
    if ! execute_build_steps "$build_dir" "$configure_command" "$BUILD_JOBS" "$prefix"; then
        return 1
    fi

    # Create additional symlinks
    ln -sf "$prefix/bin/python3.9" "$prefix/bin/python"
    ln -sf "$prefix/bin/pip3.9" "$prefix/bin/pip"

    local modulefile_path=$(write_modulefile python "$version" personal)
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created: $modulefile_path" "INFO"
        echo "module load openssl/openssl-${PUBLIC_SOFTWARE[openssl]}" >> "$modulefile_path"
    else
        log "Failed to create modulefile for Python" "ERROR"
    fi
    log "Python $version installed successfully" "SUCCESS"
}

