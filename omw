#!/bin/bash
set -eo pipefail

if ((BASH_VERSINFO[0] < 4)); then
	echo "ERROR: OMW requires Bash 4 or newer. Current Bash: ${BASH_VERSION:-unknown}" >&2
	exit 2
fi

OMW_HOME=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

declare -a SOFTWARE_LIST APP_LIST CONFIG_BACKUP_PATHS
declare -A SOFTWARE_VERSIONS SOFTWARE_URLS SOFTWARE_DEPS SOFTWARE_CONFIG_CMDS SOFTWARE_CFLAGS SOFTWARE_LDFLAGS
declare -A APP_VERSIONS APP_URLS APP_EXECUTABLE_NAME APP_SOURCE_URLS APP_BIN_DIRS

# Trap SIGINT (Ctrl+C) for graceful shutdown
_omw_cli_handle_sigint() {
	omw_log "Interrupt signal (SIGINT) received. Exiting..." "WARN"
	exit 130
}
trap '_omw_cli_handle_sigint' SIGINT

_omw_cli_source_module() {
	local module="$1"
	local path="$OMW_HOME/$module"

	if [[ ! -f "$path" ]]; then
		echo "ERROR: OMW module not found: $path" >&2
		exit 2
	fi
	# shellcheck source=/dev/null
	source "$path"
}

_omw_cli_source_module "lib/common.sh"
_omw_cli_source_module "lib/status.sh"
_omw_cli_source_module "lib/build.sh"
_omw_cli_source_module "lib/app.sh"
_omw_cli_source_module "lib/config.sh"
_omw_cli_source_module "lib/offline.sh"

_omw_cli_print_help() {
	cat <<-EOF
		Usage:
		  $0 <area> <action> [target] [options]
		  $0 <legacy-command> [target] [options]

		OMW - build source tools, install apps, and apply workspace configs.

		Build:
		  build <software[@version]>      Build source software
		  build all                       Build all configured source software
		  --build, -b <target>            Legacy alias for build

		App:
		  app install <app>               Install a prebuilt app
		  app install-all                 Install all prebuilt apps
		  --install, -i <app>             Legacy alias for app install
		  --install-all-apps              Legacy alias for app install-all

		Config:
		  config <tmux|vim|zsh>           Apply one shell/editor config
		  config all                      Apply tmux, vim, and zsh configs
		  init                            Add OMW env sourcing to ~/.bashrc
		  --config, -c <target>           Legacy alias for config

		Offline:
		  offline pack                    Create an offline deployment bundle
		  offline verify                  Verify offline assets
		  --pack, -p                      Legacy alias for offline pack
		  --verify-offline                Legacy alias for offline verify

		Status:
		  status                          Show installable and installed items
		  status installed                Show installed or partially installed items
		  update check                    Check supported upstream versions
		  --status, --list, --installed   Legacy status aliases
		  --check-updates                 Legacy alias for update check

		Maintenance:
		  clean <builds|packages|installs|apps|all>
		                                  packages keeps packages/config/*.tar.gz
		  all                             Run build -> app -> config

		Options:
		  --force                         Force rebuild/reinstall where supported
		  --refresh                       Only refresh modulefiles for source builds
		  -h, --help                      Show this help

		Examples:
		  $0 build vim
		  $0 build python@3.12.12 --force
		  $0 app install rg
		  $0 config zsh
		  $0 offline verify
		  $0 status installed

		Software to build: ${SOFTWARE_LIST[*]}
		Apps to install: ${APP_LIST[*]}
	EOF
}

_omw_cli_parse() {
	OMW_COMMAND=""
	OMW_TARGET=""
	OMW_FORCE=false
	OMW_REFRESH=false

	[[ $# -eq 0 ]] && {
		OMW_COMMAND="help"
		return 0
	}

	case "$1" in
	-h | --help | help)
		OMW_COMMAND="help"
		shift
		;;
	all | -a | --all)
		OMW_COMMAND="all"
		shift
		;;
	init | --init)
		OMW_COMMAND="init"
		shift
		;;
	build | -b | --build)
		OMW_COMMAND="build"
		shift
		[[ $# -gt 0 && "$1" != --* ]] && {
			OMW_TARGET="$1"
			shift
		}
		;;
	app)
		shift
		case "${1:-}" in
		install)
			OMW_COMMAND="app-install"
			shift
			[[ $# -gt 0 && "$1" != --* ]] && {
				OMW_TARGET="$1"
				shift
			}
			;;
		install-all | all)
			OMW_COMMAND="app-install-all"
			shift
			;;
		*)
			omw_log "Invalid app action. Use: app install <app> or app install-all." "ERROR"
			exit 1
			;;
		esac
		;;
	-i | --install)
		OMW_COMMAND="app-install"
		shift
		[[ $# -gt 0 && "$1" != --* ]] && {
			OMW_TARGET="$1"
			shift
		}
		;;
	--install-all-apps)
		OMW_COMMAND="app-install-all"
		shift
		;;
	config | -c | --config)
		OMW_COMMAND="config"
		shift
		[[ $# -gt 0 && "$1" != --* ]] && {
			OMW_TARGET="$1"
			shift
		}
		;;
	offline)
		shift
		case "${1:-}" in
		pack)
			OMW_COMMAND="offline-pack"
			shift
			;;
		verify)
			OMW_COMMAND="offline-verify"
			shift
			;;
		*)
			omw_log "Invalid offline action. Use: offline pack or offline verify." "ERROR"
			exit 1
			;;
		esac
		;;
	-p | --pack)
		OMW_COMMAND="offline-pack"
		shift
		;;
	--verify-offline)
		OMW_COMMAND="offline-verify"
		shift
		;;
	status | --status | --list)
		OMW_COMMAND="status"
		shift
		if [[ "${1:-}" == "installed" ]]; then
			OMW_TARGET="installed"
			shift
		fi
		;;
	--installed)
		OMW_COMMAND="status"
		OMW_TARGET="installed"
		shift
		;;
	update)
		shift
		if [[ "${1:-}" != "check" ]]; then
			omw_log "Invalid update action. Use: update check." "ERROR"
			exit 1
		fi
		OMW_COMMAND="update-check"
		shift
		;;
	--check-updates)
		OMW_COMMAND="update-check"
		shift
		;;
	clean | --clean)
		OMW_COMMAND="clean"
		shift
		[[ $# -gt 0 && "$1" != --* ]] && {
			OMW_TARGET="$1"
			shift
		}
		;;
	*)
		omw_log "Invalid command: $1" "ERROR"
		_omw_cli_print_help
		exit 1
		;;
	esac

	while [[ $# -gt 0 ]]; do
		case "$1" in
		--force)
			OMW_FORCE=true
			shift
			;;
		--refresh)
			OMW_REFRESH=true
			shift
			;;
		-h | --help)
			OMW_COMMAND="help"
			shift
			;;
		*)
			omw_log "Unexpected argument for '$OMW_COMMAND': $1" "ERROR"
			exit 1
			;;
		esac
	done
}

_omw_cli_requires_sys_deps() {
	case "$1" in
	help | init | status | update-check) return 1 ;;
	*) return 0 ;;
	esac
}

_omw_cli_require_target() {
	local command="$1"
	local target="$2"
	local hint="$3"

	[[ -n "$target" ]] && return 0
	omw_log "$command requires a target. $hint" "ERROR"
	exit 1
}

_omw_cli_run_build_all() {
	local sw version versions_str count=0
	for sw in "${SOFTWARE_LIST[@]}"; do
		versions_str="${SOFTWARE_VERSIONS[$sw]}"
		[[ -z "$versions_str" ]] && continue
		for version in $versions_str; do
			((++count))
			omw_log "Build target $count: $sw@$version" "INFO"
			omw_ensure_module_command || exit 1
			module purge || exit 1
			omw_build_software "$sw@$version" "$OMW_FORCE" "$OMW_REFRESH" || exit 1
		done
	done
	if ((count == 0)); then
		omw_log "No source build targets are defined in packages.sh." "ERROR"
		exit 1
	fi
}

_omw_cli_run_all() {
	local app

	omw_log "Phase 1/3: build source software (${#SOFTWARE_LIST[@]} package definitions)" "INFO"
	_omw_cli_run_build_all
	omw_log "Phase 2/3: apply configs" "INFO"
	for app in tmux vim zsh; do omw_configure "$app" "$OMW_FORCE" || exit 1; done
	omw_log "Phase 3/3: install prebuilt apps (${#APP_LIST[@]} app definitions)" "INFO"
	for app in "${APP_LIST[@]}"; do omw_install_app "$app" "$OMW_FORCE" || exit 1; done

}

_omw_cli_run_build() {
	local target="$1"
	local appname version versions_str v

	_omw_cli_require_target "build" "$target" "Example: $0 build vim or $0 build python@3.12.12"
	if [[ "$target" == "all" ]]; then
		_omw_cli_run_build_all
		return 0
	fi

	read -r appname version < <(omw_parse_target "$target")
	if [[ -z "$version" ]]; then
		omw_log "No version specified for '$appname'. Building all defined versions." "INFO"
		versions_str="${SOFTWARE_VERSIONS[$appname]:-}"
		if [[ -z "$versions_str" ]]; then
			omw_log "No versions defined for '$appname' in packages.sh." "ERROR"
			exit 1
		fi
		for v in $versions_str; do
			omw_build_software "$appname@$v" "$OMW_FORCE" "$OMW_REFRESH" || exit 1
		done
	else
		omw_build_software "$target" "$OMW_FORCE" "$OMW_REFRESH" || exit 1
	fi
}

_omw_cli_run_config() {
	local target="$1"

	_omw_cli_require_target "config" "$target" "Use: $0 config tmux, vim, zsh, or all."
	case "$target" in
	all)
		omw_configure "tmux" "$OMW_FORCE" || exit 1
		omw_configure "vim" "$OMW_FORCE" || exit 1
		omw_configure "zsh" "$OMW_FORCE" || exit 1
		;;
	tmux | vim | zsh)
		omw_configure "$target" "$OMW_FORCE" || exit 1
		;;
	*)
		omw_log "Invalid config target. Use: tmux, vim, zsh, all." "ERROR"
		exit 1
		;;
	esac
}

_omw_cli_run_clean() {
	local target="$1"

	_omw_cli_require_target "clean" "$target" "Use: $0 clean builds, packages, installs, apps, or all."
	omw_log "Cleaning $target..."
	case "$target" in
	builds) omw_safe_rm_rf "$BUILDS_PATH" ;;
	packages) _omw_cli_clean_packages ;;
	installs)
		omw_safe_rm_rf "$SOFTWARE_INSTALL_PATH"
		omw_safe_rm_rf "$MODULEFILES_PATH"
		;;
	apps)
		omw_safe_rm_rf "$APPS_INSTALL_PATH"
		omw_clear_directory_contents "$SCRIPTS_BIN_PATH"
		;;
	all)
		omw_safe_rm_rf "$BUILDS_PATH"
		_omw_cli_clean_packages
		omw_safe_rm_rf "$OMW_HOME/tools"
		omw_safe_rm_rf "$APPS_INSTALL_PATH"
		omw_clear_directory_contents "$SCRIPTS_BIN_PATH"
		;;
	*)
		omw_log "Invalid clean target. Use: builds, packages, installs, apps, all." "ERROR"
		exit 1
		;;
	esac
	omw_log "Clean complete." "SUCCESS"
}

_omw_cli_clean_packages() {
	local item base

	mkdir -p "$PACKAGES_PATH"
	for item in "$PACKAGES_PATH"/* "$PACKAGES_PATH"/.[!.]* "$PACKAGES_PATH"/..?*; do
		[[ -e "$item" || -L "$item" ]] || continue
		base=$(basename "$item")
		[[ "$base" == "config" ]] && continue
		omw_safe_rm_rf "$item"
	done
	mkdir -p "$PACKAGES_PATH/config"
}

_omw_cli_run_command() {
	case "$OMW_COMMAND" in
	help) _omw_cli_print_help ;;
	init) omw_init_shell_env || exit 1 ;;
	all) _omw_cli_run_all ;;
	build) _omw_cli_run_build "$OMW_TARGET" ;;
	app-install)
		_omw_cli_require_target "app install" "$OMW_TARGET" "Example: $0 app install rg"
		omw_install_app "$OMW_TARGET" "$OMW_FORCE" || exit 1
		;;
	app-install-all)
		local app
		for app in "${APP_LIST[@]}"; do omw_install_app "$app" "$OMW_FORCE" || exit 1; done
		;;
	config) _omw_cli_run_config "$OMW_TARGET" ;;
	offline-pack) omw_create_offline_bundle || exit 1 ;;
	offline-verify) omw_verify_offline || exit 1 ;;
	status)
		if [[ "$OMW_TARGET" == "installed" ]]; then
			omw_print_status "false"
		else
			omw_print_status "true"
		fi
		;;
	update-check) omw_check_updates || exit 1 ;;
	clean) _omw_cli_run_clean "$OMW_TARGET" ;;
	*)
		omw_log "No command specified." "WARN"
		_omw_cli_print_help
		exit 1
		;;
	esac
}

main() {
	omw_init_globals
	_omw_cli_parse "$@"
	if _omw_cli_requires_sys_deps "$OMW_COMMAND"; then
		omw_check_sys_deps
	fi
	_omw_cli_run_command
}

main "$@"
