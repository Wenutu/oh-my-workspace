# Configuration Management
###############################################################################

# Configure tmux with Oh My Tmux
config_tmux() {
    local version=${PERSONAL_SOFTWARE[tmux]}
    local config_dir="$CONFIG_PATH/tmux/tmux-$version"
    local repo_url="https://github.com/gpakosz/.tmux.git"
    local package_path="$PACKAGES_PATH/config/tmux-$version-config.tar.gz"

    log "###############################################################################"
    log "# Configuring tmux"
    log "###############################################################################"

    log "Configuring tmux..." "INFO"

    # Backup existing configuration
    [[ -f "$HOME/.tmux.conf" ]] && mv "$HOME/.tmux.conf" "$HOME/.tmux.conf.bak"
    [[ -d "$HOME/.tmux" ]] && mv "$HOME/.tmux" "$HOME/.tmux.bak"
    
    if [[ ! -d "$config_dir" ]]; then
        mkdir -p "$config_dir"
    fi
    if [[ -d "$config_dir/.tmux" ]]; then
        log "Oh My Tmux already cloned" "INFO"
    elif [[ -f "$package_path" ]]; then
        log "Extracting configuration package..." "INFO"
        extract_package "$package_path" "$config_dir"
    else
        log "Cloning Oh My Tmux..." "INFO"
        git clone --depth 1 "$repo_url" "$config_dir/.tmux"
    fi
    # Create symlinks
    ln -sf "$config_dir/.tmux/.tmux.conf" "$HOME/.tmux.conf"
    ln -sf "$config_dir/.tmux/.tmux.conf.local" "$HOME/.tmux.conf.local"

    log "tmux configuration complete" "SUCCESS"
}

# Configure Zsh with Oh My Zsh
config_zsh() {
    local version=${PERSONAL_SOFTWARE[zsh]}
    local config_dir="$CONFIG_PATH/zsh/zsh-$version"
    local repo_url="https://github.com/ohmyzsh/ohmyzsh.git"
    local package_path="$PACKAGES_PATH/config/zsh-$version-config.tar.gz"

    log "###############################################################################"
    log "# Configuring Zsh"
    log "###############################################################################"

    log "Configuring Zsh..." "INFO"

    # Backup existing configuration
    [[ -f "$HOME/.zshrc" ]] && mv "$HOME/.zshrc" "$HOME/.zshrc.bak"
    [[ -L "$HOME/.oh-my-zsh" ]] && rm "$HOME/.oh-my-zsh"

    # make config directory
    if [[ ! -d "$config_dir" ]]; then
        mkdir -p "$config_dir"
    fi

    # Clone Oh My Zsh
    if [[ -d "$config_dir/.oh-my-zsh" ]]; then
        log "Oh My Zsh already cloned" "INFO"
    elif [[ -f "$package_path" ]]; then
        log "Extracting configuration package..." "INFO"
        extract_package "$package_path" "$config_dir"
    else
        log "Cloning Oh My Zsh..." "INFO"
        git clone --depth 1 "$repo_url" "$config_dir/.oh-my-zsh"
        # Clone Powerlevel10k theme
        git clone --depth 1 https://github.com/romkatv/powerlevel10k.git \
            "$config_dir/.oh-my-zsh/custom/themes/powerlevel10k"
        # Clone autosuggestions and syntax highlighting plugins
        git clone https://github.com/zsh-users/zsh-autosuggestions \
            $config_dir/.oh-my-zsh/custom/plugins/zsh-autosuggestions
        git clone https://github.com/zsh-users/zsh-syntax-highlighting \
            $config_dir/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting
    fi
    # Create symlinks
    ln -sf "$config_dir/.oh-my-zsh" "$HOME/.oh-my-zsh"
    cp "$config_dir/.oh-my-zsh/templates/zshrc.zsh-template" "$HOME/.zshrc"

    # Add custom configuration
    cat >> "$HOME/.zshrc" <<-EOF

# OMW Configuration
export OMW_HOME="$OMW_HOME"
export PATH="\$OMW_HOME/scripts/bin:\$PATH"
export MODULEPATH="\$OMW_HOME/tools/public/modulefiles:\$OMW_HOME/tools/personal/modulefiles:\$MODULEPATH"
export PUBLIC_SOFTWARE="\$OMW_HOME/public/software"
export PERSONAL_SOFTWARE="\$OMW_HOME/personal/software"
EOF

    log "Zsh configuration complete" "SUCCESS"
}

###############################################################################
# Package Management
###############################################################################
create_config_packages() {
    log "###############################################################################"
    log "# Creating configuration packages"
    log "###############################################################################"
    if [[ ! -d "$PACKAGES_PATH/config" ]]; then
        mkdir -p "$PACKAGES_PATH/config"
    fi
    log "Creating tmux configuration package..." "INFO"
    tar -czf "$PACKAGES_PATH/config/tmux-${PERSONAL_SOFTWARE[tmux]}-config.tar.gz" -C "$CONFIG_PATH/tmux" "tmux-${PERSONAL_SOFTWARE[tmux]}"
    log "Creating Zsh configuration package..." "INFO"
    tar -czf "$PACKAGES_PATH/config/zsh-${PERSONAL_SOFTWARE[zsh]}-config.tar.gz" -C "$CONFIG_PATH/zsh" "zsh-${PERSONAL_SOFTWARE[zsh]}"
    log "Configuration packages created successfully" "SUCCESS"

    log "Creating rpms package..." "INFO"
    tar -czf "$PACKAGES_PATH/rpms.tar.gz" -C "$PUBLIC_SOFTWARE_PATH/local/build" .

    timestamp=$(date +%Y-%m-%d-%H-%M-%S)
    packages_archive="$OMW_HOME/packages-${timestamp}.tar.gz"
    log "Creating packages folder package: $packages_archive" "INFO"
    tar -czf "$packages_archive" -C "$OMW_HOME" "packages"
    log "Packages folder package created successfully: $packages_archive" "SUCCESS"
}

###############################################################################
# Main Execution
###############################################################################

main() {
    init_globals
    check_dependencies
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $0 [OPTIONS]

Options:
  -h, --help        Show this help message
  -a, --all         Install all software and configurations
  -b, --build [SOFTWARE]  Build specific software
      --force       Force rebuild existing installations
  -c, --config [SOFTWARE] Configure specific software
  --clean           Clean build directories
  -p, --pack        Create configuration packages

OWM Configuration:
  OMW_HOME: $OMW_HOME

Available software:
  Public: ${!PUBLIC_SOFTWARE[*]}
  Personal: ${!PERSONAL_SOFTWARE[*]}
  Config: tmux zsh
EOF
                exit 0
                ;;
            -a|--all)
                build_openssl
                build_libevent
                build_ncurses
                build_lua
                build_local
                build_python
                build_tmux
                build_zsh
                build_vim
                config_tmux
                config_zsh
                exit 0
                ;;
            -b|--build)
                shift
                software=$1
                shift
                case "$software" in
                    openssl|libevent|ncurses|lua|local)
                        "build_$software" "$@"
                        ;;
                    python|tmux|zsh|vim)
                        "build_$software" "$@"
                        ;;
                    *)
                        log "Unknown software: $software" "ERROR"
                        exit 1
                        ;;
                esac
                ;;
            -c|--config)
                shift
                case "$1" in
                    tmux) config_tmux ;;
                    zsh) config_zsh ;;
                    *) log "Unknown config: $1" "ERROR"; exit 1 ;;
                esac
                ;;
            --clean)
                clean
                exit 0
                ;;
            -p|--pack)
                create_config_packages
                ;;
            *)
                log "Invalid option: $1" "ERROR"
                exit 1
                ;;
        esac
        shift
    done
}

# Execute main function
main "$@"