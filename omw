# Build Ncurses with wide-character support
build_ncurses() {
    local force=${1:-false}
    local version=${PUBLIC_SOFTWARE[ncurses]}
    local prefix="$PUBLIC_SOFTWARE_PATH/ncurses/ncurses-$version"
    local pkg_url="https://ftp.gnu.org/gnu/ncurses/ncurses-$version.tar.gz"
    local pkg_path="$PACKAGES_PATH/software/ncurses-$version.tar.gz"
    local build_dir="$PUBLIC_SOFTWARE_PATH/ncurses/build"

    log "###############################################################################"
    log "# Building Ncurses $version"
    log "###############################################################################"

    [[ "$force" == "force" ]] && rm -rf "$prefix" "$build_dir"

    if [[ -d "$prefix" ]]; then
        log "Ncurses $version already installed" "INFO"
        return 0
    fi

    download_package "$pkg_url" "$pkg_path"
    extract_package "$pkg_path" "$build_dir"

    local configure_normal="./configure --prefix=$prefix --with-normal --disable-widec --with-shared --with-termlib --enable-pc-files --with-pkg-config-libdir=$prefix/lib/pkgconfig --enable-overwrite"
    local configure_widec="./configure --prefix=$prefix --with-normal --enable-widec --with-shared --with-termlib --enable-pc-files --with-pkg-config-libdir=$prefix/lib/pkgconfig --enable-overwrite"

    log "Configuring Ncurses $version (normal)..." "INFO"
    if ! execute_build_steps "$build_dir" "$configure_normal" "$BUILD_JOBS" "$prefix"; then
        return 1
    fi

    log "Configuring Ncurses $version (widec)..." "INFO"
    if ! execute_build_steps "$build_dir" "$configure_widec" "$BUILD_JOBS" "$prefix"; then
        return 1
    fi

    local modulefile_path=$(write_modulefile ncurses "$version" public "-I\$prefix/include" "-L\$prefix/lib -lncurses -lncursesw -ltinfo -ltinfow")
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created: $modulefile_path" "INFO"
    else
        log "Failed to create modulefile for Ncurses" "ERROR"
    fi
    log "Ncurses $version installed successfully" "SUCCESS"
}

