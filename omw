build_vim() {
    local force=${1:-false}
    local version=${PERSONAL_SOFTWARE[vim]}
    local prefix="$PERSONAL_SOFTWARE_PATH/vim/vim-$version"
    local pkg_url="https://github.com/vim/vim/archive/refs/tags/v$version.tar.gz"
    local pkg_path="$PACKAGES_PATH/software/vim-$version.tar.gz"
    local build_dir="$PERSONAL_SOFTWARE_PATH/vim/build"

    log "###############################################################################"
    log "# Building Vim $version"
    log "###############################################################################"

    [[ "$force" == "force" ]] && rm -rf "$prefix" "$build_dir"

    if [[ -d "$prefix" ]]; then
        log "Vim $version already installed" "INFO"
        return 0
    fi

    download_package "$pkg_url" "$pkg_path"
    extract_package "$pkg_path" "$build_dir"

    # Load dependencies
    module load ncurses/ncurses-${PUBLIC_SOFTWARE[ncurses]}
    module load lua/lua-${PUBLIC_SOFTWARE[lua]}
    module load python/python-${PERSONAL_SOFTWARE[python]}
    module load local/local-${PUBLIC_SOFTWARE[local]}

    local configure_command="./configure --prefix=$prefix --with-features=huge --enable-multibyte --enable-perlinterp --enable-luainterp=yes --with-lua-prefix=$PUBLIC_SOFTWARE_PATH/lua/lua-${PUBLIC_SOFTWARE[lua]} --enable-pythoninterp --enable-python3interp=yes --with-python3-config-dir=$(python3-config --configdir) --enable-gui=gtk3 --with-tlib=ncursesw --enable-cscope --enable-fontset --with-compiledby=Wentao\ Shi"
    #local configure_command="./configure --prefix=$prefix --with-features=huge --enable-multibyte --enable-luainterp=yes --with-lua-prefix=$PUBLIC_SOFTWARE_PATH/lua/lua-${PUBLIC_SOFTWARE[lua]} --enable-pythoninterp --enable-python3interp=yes --with-python3-config-dir=$(python3-config --configdir) --enable-gui=gtk3 --with-tlib=ncursesw --enable-cscope --enable-fontset --with-compiledby='Wentao Shi'"

    if ! execute_build_steps "$build_dir" "$configure_command" "$BUILD_JOBS" "$prefix"; then
        return 1
    fi

    local modulefile_path=$(write_modulefile vim "$version" personal)
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created: $modulefile_path" "INFO"
        echo "module load ncurses/ncurses-${PUBLIC_SOFTWARE[ncurses]}" >> "$modulefile_path"
        echo "module load lua/lua-${PUBLIC_SOFTWARE[lua]}" >> "$modulefile_path"
        echo "module load python/python-${PERSONAL_SOFTWARE[python]}" >> "$modulefile_path"
        echo "module load local/local-${PUBLIC_SOFTWARE[local]}" >> "$modulefile_path"
    else
        log "Failed to create modulefile for Vim" "ERROR"
    fi
    log "Vim $version installed successfully" "SUCCESS"
}

