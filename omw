#!/bin/bash
set -eo pipefail

# declare global spinner_pid
declare spinner_pid

handle_sigint() {
    log "Intr SIGINT handler..." "WARN"
    stop_spinner
    echo "pid: $spinner_pid"
    kill $spinner_pid 2>/dev/null
    exit 130
}

trap 'handle_sigint' SIGINT

