#!/bin/bash
set -eo pipefail

declare spinner_pid

# Trap SIGINT (Ctrl+C) for graceful shutdown
handle_sigint() {
	log "Interrupt signal (SIGINT) received. Exiting..." "WARN"
	stop_spinner
	exit 130
}
trap 'handle_sigint' SIGINT

###############################################################################
# Global Configuration and Initialization
###############################################################################
init_globals() {
	OMW_HOME=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
	# Source environment variables if they exist
	[[ -f "$OMW_HOME/env.sh" ]] && source "$OMW_HOME/env.sh"

	# Define core paths
	CONFIG_PATH="$OMW_HOME/config"
	PACKAGES_PATH="$OMW_HOME/packages"
	BUILDS_PATH="$OMW_HOME/builds"
	SOFTWARE_INSTALL_PATH="$OMW_HOME/tools/software"
	MODULEFILES_PATH="$OMW_HOME/tools/modulefiles"
	APPS_INSTALL_PATH="$OMW_HOME/apps"
	SCRIPTS_BIN_PATH="$OMW_HOME/bin"

	# Ensure core directories exist
	readonly DIRECTORIES=(
		"$CONFIG_PATH" "$PACKAGES_PATH/software" "$PACKAGES_PATH/apps"
		"$BUILDS_PATH" "$SOFTWARE_INSTALL_PATH" "$MODULEFILES_PATH" "$APPS_INSTALL_PATH" "$SCRIPTS_BIN_PATH"
	)
	for dir in "${DIRECTORIES[@]}"; do
		[[ ! -d "$dir" ]] && mkdir -p "$dir"
	done

	# Load software definitions from configuration file
	local conf_file="$OMW_HOME/software.conf"
	if [[ -f "$conf_file" ]]; then
		log "Loading definitions from $conf_file" "INFO"
		source "$conf_file"
	else
		log "Configuration file not found: $conf_file. Cannot proceed." "ERROR"
		exit 1
	fi

	# Set build-related constants
	local core_count
	core_count=$(nproc)
	if ((core_count > 2)); then
		readonly BUILD_JOBS=$((core_count - 2))
	else
		readonly BUILD_JOBS=1
	fi

	readonly MAX_RETRIES=3
	readonly DOWNLOAD_TIMEOUT=300
	readonly GCC_PREREQ_BASE_URL='http://gcc.gnu.org/pub/gcc/infrastructure/'
	return 0
}

###############################################################################
# Utility Functions
###############################################################################
log() {
	local msg="$1"
	local level="${2:-INFO}"
	local ts
	ts=$(date +"%T")
	declare -A c=([DEBUG]=34 [INFO]=36 [WARN]=33 [ERROR]=31 [SUCCESS]=32)
	echo -e "\033[1;${c[$level]:-36}m[${ts}] [${level}] - ${msg}\033[0m" >&2
}

start_spinner() {
	[[ "$OMW_NO_SPINNER" == "1" ]] && return 0
	spinner &
	spinner_pid=$!
}

stop_spinner() {
	if [[ -n "$spinner_pid" ]]; then
		# Kill the spinner process and wait for it to terminate
		kill -s TERM "$spinner_pid" 2>/dev/null
		wait "$spinner_pid" 2>/dev/null
		spinner_pid=""
	fi
	echo -ne "\r\033[K" >&2
}

spinner() {
	trap 'exit 0' TERM
	while :; do
		for c in / - \\ \|; do
			echo -ne "\r\033[1;36m[INFO] $(date +"%T") - Processing ${c}" >&2
			sleep 0.1
		done
	done
}

check_sys_deps() {
	log "Checking system dependencies..." "INFO"
	local missing_deps=0
	for cmd in wget tar make git rpm2cpio cpio sed find nproc yumdownloader unzip pushd popd; do
		if ! command -v "$cmd" &>/dev/null; then
			log "Missing command: $cmd" "ERROR"
			missing_deps=1
		fi
	done
	if ((missing_deps)); then exit 1; fi
	log "System dependencies are satisfied." "SUCCESS"
	return 0
}

# NEW: Helper function to get the URL for a specific software version
_get_software_url() {
	local appname="$1"
	local version="$2"
	local url_template="${SOFTWARE_URLS[$appname]}"
	# Replace the {VERSION} placeholder with the actual version number
	echo "${url_template//\{VERSION\}/$version}"
}

download_package() {
	local url="$1"
	local dest="$2"
	# Check if package already exists and is reasonably sized
	if [[ -f "$dest" && $(stat -c%s "$dest") -gt 100 ]]; then
		log "Package exists: $(basename "$dest")" "INFO"
		return 0
	fi
	[[ -f "$dest" ]] && rm -f "$dest"
	log "Downloading $(basename "$dest")" "INFO"
	mkdir -p "$(dirname "$dest")"
	for ((i = 1; i <= MAX_RETRIES; i++)); do
		local log_file
		log_file=$(mktemp)
		if wget --tries=1 --timeout="$DOWNLOAD_TIMEOUT" -o "$log_file" -O "$dest" "$url" && [[ $(stat -c%s "$dest") -gt 100 ]]; then
			rm -f "$log_file"
			log "Download successful." "SUCCESS"
			return 0
		fi
		log "Download attempt $i failed. Retrying..." "WARN"
	done
	log "Failed to download $url. Last attempt log:" "ERROR"
	cat "$log_file" >&2
	rm -f "$log_file"
	return 1
}

extract_package() {
	local pkg="$1"
	local dest="$2"
	local strip="${3:-1}"
	log "Extracting $(basename "$pkg") to $(basename "$dest")" "INFO"
	mkdir -p "$dest"
	case "$pkg" in
	*.tar.gz | *.tgz) tar -xzf "$pkg" -C "$dest" --strip-components="$strip" ;;
	*.tar.xz) tar -xJf "$pkg" -C "$dest" --strip-components="$strip" ;;
	*.tar.bz2) tar -xjf "$pkg" -C "$dest" --strip-components="$strip" ;;
	*.zip) unzip -q "$pkg" -d "$dest" ;;
	*)
		log "Unsupported format: $pkg" "ERROR"
		return 1
		;;
	esac
	if [[ -z "$(ls -A "$dest")" ]]; then
		log "Extraction failed: destination is empty." "ERROR"
		return 1
	fi
	log "Extraction successful." "SUCCESS"
}

# Helper function to parse GCC's download_prerequisites script
_get_gcc_prereq_pkgs() {
	local extracted_gcc_path="$1"
	local prereq_script="$extracted_gcc_path/contrib/download_prerequisites"

	if [[ ! -f "$prereq_script" ]]; then
		log "download_prerequisites script not found in $extracted_gcc_path" "ERROR"
		return 1
	fi
	# Use an array to store results, which handles potential future changes better
	local prereqs=(
		"$(grep -oP 'gmp-.*tar\.bz2' "$prereq_script" | head -1 || true)"
		"$(grep -oP 'mpfr-.*tar\.bz2' "$prereq_script" | head -1 || true)"
		"$(grep -oP 'mpc-.*tar\.gz' "$prereq_script" | head -1 || true)"
		"$(grep -oP 'isl-.*tar\.bz2' "$prereq_script" | head -1 || true)"
	)
	# Print non-empty package names
	for pkg in "${prereqs[@]}"; do
		[[ -n "$pkg" ]] && echo "$pkg"
	done
}

# MODIFIED: Prefetch GCC prerequisites for all defined versions
prefetch_gcc_prereqs() {
	local versions_str="${SOFTWARE_VERSIONS[gcc]}"
	[[ -z "$versions_str" ]] && return 0 # Skip if GCC is not defined

	log "Prefetching GCC prerequisites for all defined versions..." "INFO"

	for version in $versions_str; do
		local url
		url=$(_get_software_url "gcc" "$version")
		local gcc_pkg="$PACKAGES_PATH/software/$(basename "$url")"
		local tmp_dir="$BUILDS_PATH/.prefetch-gcc-$version"

		# Ensure GCC main package is downloaded
		download_package "$url" "$gcc_pkg"

		# Extract just to parse the prerequisites script
		rm -rf "$tmp_dir"
		mkdir -p "$tmp_dir"
		extract_package "$gcc_pkg" "$tmp_dir" 1

		local prereq_pkgs
		mapfile -t prereq_pkgs < <(_get_gcc_prereq_pkgs "$tmp_dir")

		for pkg in "${prereq_pkgs[@]}"; do
			local dest="$PACKAGES_PATH/software/$pkg"
			download_package "${GCC_PREREQ_BASE_URL}${pkg}" "$dest"
		done

		rm -rf "$tmp_dir"
	done
	log "All GCC prerequisites prefetched." "SUCCESS"
}

# Generate SHA256 checksums for all packages
write_checksums() {
	local sums_file="$PACKAGES_PATH/SHA256SUMS"
	if command -v sha256sum &>/dev/null; then
		log "Generating checksums..." "INFO"
		# Exclude existing checksum file to avoid recursion
		find "$PACKAGES_PATH" -type f ! -name "SHA256SUMS" -print0 | sort -z | xargs -0 sha256sum >"$sums_file"
		log "Checksums written to $sums_file" "SUCCESS"
	else
		log "sha256sum not available. Skipping checksum generation." "WARN"
	fi
}

# MODIFIED: Verify offline completeness for all defined software versions
verify_offline() {
	log "--- Verifying offline completeness ---" "INFO"
	local missing=()

	# 1) Source and precompiled packages
	for sw in "${SOFTWARE_LIST[@]}"; do
		local versions_str="${SOFTWARE_VERSIONS[$sw]}"
		[[ -z "$versions_str" ]] && continue
		for version in $versions_str; do
			local url
			url=$(_get_software_url "$sw" "$version")
			[[ -z "$url" ]] && continue
			local p="$PACKAGES_PATH/software/$(basename "$url")"
			[[ -f "$p" ]] || missing+=("$p")
		done
	done

	for app in "${APP_LIST[@]}"; do
		local url="${APP_URLS[$app]}"
		[[ -z "$url" ]] && continue
		local p="$PACKAGES_PATH/apps/$(basename "$url")"
		[[ -f "$p" ]] || missing+=("$p")
	done

	# 2) GCC prerequisites (if GCC is defined in config) for all versions
	local gcc_versions_str="${SOFTWARE_VERSIONS[gcc]}"
	if [[ -n "$gcc_versions_str" ]]; then
		for version in $gcc_versions_str; do
			local gcc_url
			gcc_url=$(_get_software_url "gcc" "$version")
			local gcc_pkg="$PACKAGES_PATH/software/$(basename "$gcc_url")"

			if [[ -f "$gcc_pkg" ]]; then
				local tmp_dir="$BUILDS_PATH/.verify-gcc-prereqs-$version"
				rm -rf "$tmp_dir"
				mkdir -p "$tmp_dir"
				extract_package "$gcc_pkg" "$tmp_dir" 1
				local prereq_pkgs
				mapfile -t prereq_pkgs < <(_get_gcc_prereq_pkgs "$tmp_dir")
				rm -rf "$tmp_dir"
				for pkg in "${prereq_pkgs[@]}"; do
					local p="$PACKAGES_PATH/software/$pkg"
					[[ -f "$p" ]] || missing+=("$p")
				done
			else
				missing+=("$gcc_pkg")
			fi
		done
	fi

	# 3) Local RPM packages bundle
	[[ -f "$PACKAGES_PATH/rpms.tar.gz" ]] || missing+=("$PACKAGES_PATH/rpms.tar.gz")

	# 4) Config git repos
	[[ -d "$CONFIG_PATH/tmux/.tmux" ]] || missing+=("$CONFIG_PATH/tmux/.tmux (git repo)")
	[[ -d "$CONFIG_PATH/zsh/.oh-my-zsh" ]] || missing+=("$CONFIG_PATH/zsh/.oh-my-zsh (git repo)")

	if ((${#missing[@]} > 0)); then
		log "Missing offline assets:" "ERROR"
		for m in "${missing[@]}"; do echo "  - $m" >&2; done
		return 1
	fi
	log "Offline assets look complete." "SUCCESS"
}

###############################################################################
# Core Build and Install Logic
###############################################################################

# A generic function to execute the configure, make, make install sequence
execute_build_steps() {
	local build_dir="$1"
	local configure_cmd_template="$2"
	local prefix="$3"
	log "Starting build process in $(basename "$build_dir")" "INFO"
	local log_dir="$build_dir/logs"
	mkdir -p "$log_dir"
	pushd "$build_dir" >/dev/null

	log "Build prefix: $prefix" "DEBUG"
	log "CFLAGS: $CFLAGS" "DEBUG"
	log "LDFLAGS: $LDFLAGS" "DEBUG"
	log "LD_LIBRARY_PATH: $LD_LIBRARY_PATH" "DEBUG"
	log "PKG_CONFIG_PATH: $PKG_CONFIG_PATH" "DEBUG"

	for step in "configure" "make" "install"; do
		local cmd
		local log_file
		case "$step" in
		"configure")
			# Use eval to expand variables like $prefix within the command string template
			cmd=$(eval echo "\"$configure_cmd_template\"")
			log_file="$log_dir/configure.log"
			;;
		"make")
			cmd="make -j $BUILD_JOBS"
			log_file="$log_dir/make.log"
			;;
		"install")
			cmd="make install"
			log_file="$log_dir/install.log"
			;;
		esac

		log "Step: $step... (log: $log_file)" "INFO"
		log "Executing command: $cmd" "DEBUG"
		start_spinner
		if ! bash -c "$cmd" &>"$log_file"; then
			stop_spinner
			log "Step '$step' failed. See details below." "ERROR"
			tail -n 20 "$log_file" >&2
			popd >/dev/null
			return 1
		fi
		stop_spinner
		log "Step '$step' completed." "SUCCESS"
	done
	popd >/dev/null
}

# --- Dedicated Build Functions for Each Software ---

_build_ncurses() {
	local build_dir="$1"
	local prefix="$2"
	# local config_cmd="./configure --prefix=$prefix --with-shared --enable-pc-files --enable-widec"
	local config_cmd="./configure --prefix=$prefix --with-normal --disable-widec --with-shared --with-termlib --enable-pc-files --with-pkg-config-libdir=$prefix/lib/pkgconfig --enable-overwrite"
	execute_build_steps "$build_dir" "$config_cmd" "$prefix"
	config_cmd="./configure --prefix=$prefix --with-normal --enable-widec --with-shared --with-termlib --enable-pc-files --with-pkg-config-libdir=$prefix/lib/pkgconfig --enable-overwrite"
	execute_build_steps "$build_dir" "$config_cmd" "$prefix"
}

_build_lua() {
	local build_dir="$1"
	local prefix="$2"
	pushd "$build_dir" >/dev/null
	# Lua uses a non-standard build process
	local make_cmd="make linux INSTALL_TOP=$prefix MYCFLAGS=-fPIC"
	local install_cmd="make install INSTALL_TOP=$prefix"
	log "Executing command: $make_cmd" "DEBUG"
	if ! $make_cmd >"$build_dir/make.log" 2>&1; then
		log "make step failed for lua. Check make.log" "ERROR"
		popd >/dev/null
		return 1
	fi
	log "Executing command: $install_cmd" "DEBUG"
	if ! $install_cmd >>"$build_dir/make.log" 2>&1; then
		log "install step failed for lua. Check make.log" "ERROR"
		popd >/dev/null
		return 1
	fi
	popd >/dev/null
}

_build_gcc() {
	local build_dir="$1"
	local prefix="$2"
	pushd "$build_dir" >/dev/null

	log "Preparing GCC prerequisites from local packages..." "INFO"
	local prereq_pkgs
	mapfile -t prereq_pkgs < <(_get_gcc_prereq_pkgs "$build_dir")
	for pkg in "${prereq_pkgs[@]}"; do
		local pkg_path="$PACKAGES_PATH/software/$pkg"
		if [[ ! -f "$pkg_path" ]]; then
			log "Prerequisite package '$pkg' not found. Please run '--pack' or prefetch." "ERROR"
			popd >/dev/null
			return 1
		fi
		# The GCC build expects the extracted source directory, not a symlink
		local prereq_name
		prereq_name="${pkg%%.tar.*}"
		extract_package "$pkg_path" "$build_dir/$prereq_name" 1
	done

	popd >/dev/null
	local config_cmd="./configure --prefix=$prefix --disable-multilib --enable-languages=c,c++,fortran"
	execute_build_steps "$build_dir" "$config_cmd" "$prefix"
}

_build_vim() {
	local build_dir="$1"
	local prefix="$2"
	local _ version # Get version from prefix
	version=$(basename "$prefix")
	version=${version#vim-}
	# MODIFIED: Dynamically find the correct Lua version based on vim's dependency
	local lua_dep
	lua_dep=$(echo "${SOFTWARE_DEPS["vim@$version"]}" | grep -o 'lua@[^ ]*' | head -n 1)
	local lua_name lua_version
	lua_name=${lua_dep%@*}
	lua_version=${lua_dep#*@}
	local py_cfg
	py_cfg=$(python3-config --configdir 2>/dev/null || echo "") # Fails gracefully
	if [[ -z "$py_cfg" ]]; then
		log "python3-config not found. Building vim without python3 support." "WARN"
	fi
	local config_cmd="./configure --prefix=$prefix --with-features=huge --enable-multibyte --enable-perlinterp --enable-luainterp=yes --with-lua-prefix=${SOFTWARE_INSTALL_PATH}/${lua_name}/${lua_name}-${lua_version} --enable-python3interp=yes --with-python3-config-dir=$py_cfg --enable-gui=gtk3 --with-tlib=ncursesw --enable-cscope --enable-fontset --with-compiledby=OMW"
	execute_build_steps "$build_dir" "$config_cmd" "$prefix"
}

_build_ctags() {
	local build_dir="$1"
	local prefix="$2"
	pushd "$build_dir" >/dev/null
	./autogen.sh >"$build_dir/autogen.log" 2>&1
	popd >/dev/null
	local config_cmd="./configure --prefix=$prefix"
	execute_build_steps "$build_dir" "$config_cmd" "$prefix"
}

# Default build function for software that follows the standard ./configure pattern
_build_default() {
	local appname="$1"
	local build_dir="$2"
	local prefix="$3"
	local config_cmd_template="${SOFTWARE_CONFIG_CMDS[$appname]}"
	execute_build_steps "$build_dir" "$config_cmd_template" "$prefix"
}

# NEW: Helper function to parse 'name@version' string
_parse_target() {
	local target_str="$1"
	local appname="${target_str%@*}"
	local version="${target_str#*@}"
	# If no version is specified, it's just the appname
	if [[ "$appname" == "$version" ]]; then
		version=""
	fi
	# Return as a string to be read by the caller
	echo "$appname $version"
}

# REFACTORED: Main dispatcher for building software, now handles versioning
build_software() {
	local target_str="$1" # e.g., "python@3.11.12" or "local"
	local force="${2:-false}"
	local refresh="${3:-false}"

	local appname version
	read -r appname version < <(_parse_target "$target_str")

	# Special handling for 'local' target which has no version
	if [[ "$appname" == "local" ]]; then
		# local version uses the key from the config file.
		build_local "$force" "$refresh" "${SOFTWARE_VERSIONS[local]}"
		return 0
	fi

	log "--- Building $appname $version ---" "INFO"

	if [[ "$refresh" == "true" ]]; then
		log "Refreshing modulefile for $appname@$version." "INFO"
		write_modulefile "$appname" "$version"
		log "$appname@$version modulefile refreshed." "SUCCESS"
		return 0
	fi

	# Dependency resolution now respects specific versions
	local deps="${SOFTWARE_DEPS["$appname@$version"]}"
	if [[ -n "$deps" ]]; then
		log "Processing dependencies for $appname@$version: $deps" "DEBUG"
		local dep_target # e.g., "python@3.11.12"
		for dep_target in $deps; do
			local dep_name dep_version
			read -r dep_name dep_version < <(_parse_target "$dep_target")
			# Recursively call build_software with the versioned dependency
			build_software "$dep_target"
			log "Loading module for dependency: $dep_name/$dep_name-${dep_version}" "INFO"
			module load "$dep_name/$dep_name-${dep_version}"
		done
	fi

	local prefix="$SOFTWARE_INSTALL_PATH/$appname/$appname-$version"
	if [[ -d "$prefix" && "$force" == "false" ]]; a
		write_modulefile "$appname" "$version"
		log "$appname@$version already installed. Skipping." "INFO"
		return 0
	fi

	if [[ "$force" == "true" && -d "$prefix" ]]; then
		local backup_dir="${prefix}-backup-$(date +%Y%m%d%H%M%S)"
		log "Force build: backing up existing installation to $backup_dir" "WARN"
		mv "$prefix" "$backup_dir"
	fi

	local build_dir="$BUILDS_PATH/$appname-$version"
	rm -rf "$build_dir"

	local url
	url=$(_get_software_url "$appname" "$version")
	if [[ -z "$url" ]]; then
		log "No URL template defined for $appname in configuration. Cannot proceed." "ERROR"
		return 1
	fi

	local pkg_path="$PACKAGES_PATH/software/$(basename "$url")"
	download_package "$url" "$pkg_path"
	extract_package "$pkg_path" "$build_dir"

	# Dynamically call the appropriate build function
	local build_func="_build_$appname"
	if declare -F "$build_func" >/dev/null; then
		log "Using dedicated build function for $appname." "DEBUG"
		"$build_func" "$build_dir" "$prefix"
	else
		log "Using default build function for $appname." "DEBUG"
		_build_default "$appname" "$build_dir" "$prefix"
	fi || return 1 # Exit if build function fails

	write_modulefile "$appname" "$version"
	log "$appname@$version build process completed." "SUCCESS"
}

build_local() {
	local force="${1:-false}"
	local refresh="${2:-false}"
	local version="${3}" # Version is now passed in
	local prefix="$SOFTWARE_INSTALL_PATH/local/local-$version"
	local rpm_dir="$BUILDS_PATH/local-rpms"
	local pkg_path="$PACKAGES_PATH/rpms.tar.gz"
	log "--- Handling local system dependencies ---" "INFO"

	if [[ "$refresh" == "true" ]]; then
		log "Refreshing modulefile for local." "INFO"
		write_modulefile "local" "$version"
		log "local modulefile refreshed." "SUCCESS"
		return 0
	fi
	if [[ -d "$prefix" && "$force" == "false" ]]; then
		log "Local dependencies installed. Skipping." "INFO"
		return 0
	fi
	if [[ "$force" == "true" && -d "$prefix" ]]; then
		local backup_dir="${prefix}-backup-$(date +%Y%m%d%H%M%S)"
		log "Force build: backing up local dependencies to $backup_dir" "WARN"
		mv "$prefix" "$backup_dir"
	fi

	mkdir -p "$rpm_dir"
	if [[ ! -f "$pkg_path" ]]; then
		log "Downloading system RPMs..."
		local rpms_to_download=(
			"gtk3-devel" "libX11-devel" "libXt-devel" "libSM-devel" "perl-ExtUtils-ParseXS"
			"libICE-devel" "libXpm-devel" "xorg-x11-proto-devel"
			"perl-ExtUtils-Embed" "help2man" "libXft-devel"
			"freetype-devel" "zlib-devel" "bzip2-devel" "libffi-devel"
			"sqlite-devel" "tkinter" "tcl-devel" "tk-devel" "readline-devel"
			"python3-tkinter" "xz-devel" "lzma" "autoconf" "automake"
			"binutils" "bison" "flex" "gettext" "libtool" "patch"
			"pkgconfig" "xsel"
		)
		start_spinner
		yumdownloader --downloadonly --destdir="$rpm_dir" --resolve "${rpms_to_download[@]}" >/dev/null
		stop_spinner
		find "$rpm_dir" -name "*.i686.rpm" -delete
	else
		log "Using pre-packaged RPMs from $pkg_path" "INFO"
		extract_package "$pkg_path" "$rpm_dir" 0
	fi

	mkdir -p "$prefix"
	log "Extracting RPMs to $prefix..." "INFO"
	pushd "$prefix" >/dev/null
	find "$rpm_dir" -maxdepth 1 -name "*.rpm" -print0 | while IFS= read -r -d $'\0' rpm; do
		rpm2cpio "$rpm" | cpio -idm --quiet
	done
	popd >/dev/null

	# Fix broken symlinks and pkg-config files after extraction
	find "$prefix" -type l -print0 | while IFS= read -r -d $'\0' link; do
		# The same logic as before, but inside a loop
		target=$(readlink "$link")
		if [[ ! -e "$link" ]]; then
			new_target="/lib64/$target"
			if [[ -e "$new_target" ]]; then
				ln -snf "$new_target" "$link"
			else
				# Using log function for consistency
				log "Broken symlink detected: $link -> $target" "WARN"
			fi
		fi
	done

	# find "$prefix" -name "*.pc" -exec sed -i "s|=/usr|=$prefix/usr|g" {} +
	# find "$prefix" -name "*.pc" -exec sed -i "s|-I/usr|-I$prefix/usr|g" {} +
	# find "$prefix" -name "*.pc" -exec sed -i "s|-L/usr|-L$prefix/usr|g" {} +
	find "$prefix" -name "*.pc" -exec sed -i \
		-e "s|=/usr|=$prefix/usr|g" \
		-e "s|-I/usr|-I$prefix/usr|g" \
		-e "s|-L/usr|-L$prefix/usr|g" \
		{} +

	write_modulefile "local" "$version"
	local modulefile_path="$MODULEFILES_PATH/local/local-$version"
	sed -i "s|set prefix.*|set prefix  \$base/local/local-$version/usr|g" "$modulefile_path"
	sed -i "s|\$prefix/lib|\$prefix/lib64|g" "$modulefile_path"
	cat >>"$modulefile_path" <<-EOF
		prepend-path PKG_CONFIG_PATH    \$prefix/share/pkgconfig
		prepend-path PERL5LIB           \$prefix/share/perl5
	EOF
}

# MODIFIED: Generates a modulefile with version-specific dependencies
write_modulefile() {
	local appname="$1"
	local version="$2"
	local modulefile_path="$MODULEFILES_PATH/$appname/$appname-$version"
	log "Generating modulefile for $appname@$version" "INFO"
	mkdir -p "$(dirname "$modulefile_path")"
	cat >"$modulefile_path" <<-EOF
		#%Module1.0
		proc ModulesHelp { } { puts stderr "Loads $appname version $version" }
		module-whatis "Software: $appname $version"
		set base    \$env(OMW_HOME)/tools/software
		set prefix  \$base/$appname/$appname-$version
		prepend-path PATH              \$prefix/bin
		prepend-path LIBRARY_PATH      \$prefix/lib
		prepend-path LD_LIBRARY_PATH   \$prefix/lib
		prepend-path PKG_CONFIG_PATH   \$prefix/lib/pkgconfig
		prepend-path MANPATH           \$prefix/share/man
		prepend-path C_INCLUDE_PATH    \$prefix/include
		prepend-path CPLUS_INCLUDE_PATH \$prefix/include
	EOF
	# Add custom compiler flags if defined in software.conf
	local cflags="${SOFTWARE_CFLAGS[$appname]:-}"
	local ldflags="${SOFTWARE_LDFLAGS[$appname]:-}"
	if [[ -n "$cflags" || -n "$ldflags" ]]; then
		cat >>"$modulefile_path" <<-EOF

			# Custom compiler flags
			if {[info exists env(CFLAGS)]} {
			    setenv CFLAGS "\$env(CFLAGS) ${cflags}"
			} else {
			    setenv CFLAGS "${cflags}"
			}
			if {[info exists env(LDFLAGS)]} {
			    setenv LDFLAGS "\$env(LDFLAGS) ${ldflags}"
			} else {
			    setenv LDFLAGS "${ldflags}"
			}
		EOF
	fi
	# Add dependencies with specific versions
	local deps="${SOFTWARE_DEPS["$appname@$version"]:-}"
	if [[ -n "$deps" ]]; then
		echo "" >>"$modulefile_path"
		local dep_target
		for dep_target in $deps; do
			local dep_name dep_version
			read -r dep_name dep_version < <(_parse_target "$dep_target")
			echo "module load $dep_name/$dep_name-${dep_version}" >>"$modulefile_path"
		done
	fi
}

_install_autojump() {
	local appname="$1"
	local install_dir="$2"
	local exec_path
	exec_path=$(find "$install_dir" -type f -name "install.py" | head -n 1)
	[[ -z "$exec_path" ]] && {
		log "autojump install.py not found in $install_dir." "ERROR"
		return 1
	}
	if [[ ! -f "$exec_path" ]]; then
		log "autojump install.py not found in $install_dir." "ERROR"
		return 1
	fi
	rm -rf "$HOME/.autojump"
	# Run the install script
	local dirname
	dirname=$(dirname "$exec_path")
	log "Running autojump installer in $dirname" "INFO"
	pushd "$dirname" >/dev/null
	"./install.py" >/dev/null
	popd >/dev/null
	if [[ $? -ne 0 ]]; then
		log "autojump installation failed." "ERROR"
		return 1
	fi
	# add source autojump to shell config
	local zshrc="$HOME/.zshrc_custom"
	[[ ! -f "$zshrc" ]] && zshrc="$HOME/.zshrc"
	if ! grep -q "autojump.sh" "$zshrc"; then
		echo -e '\n# Autojump\n[ -f "'$HOME'/.autojump/etc/profile.d/autojump.sh" ] && source "'$HOME'/.autojump/etc/profile.d/autojump.sh"' >>"$zshrc"
		log "Added autojump source line to $zshrc" "INFO"
	fi
	log "App '$appname' installed successfully." "SUCCESS"
	return 0
}

_install_default() {
	local appname="$1"
	local install_dir="$2"
	local exec_path
	exec_path=$(find "$install_dir" -type f -name "$appname" | head -n 1)
	if [[ -z "$exec_path" ]]; then
		log "Executable '$appname' not found in $install_dir." "ERROR"
		return 1
	fi
	[[ ! -x "$exec_path" ]] && {
		log "Making '$appname' executable." "WARN"
		chmod +x "$exec_path"
	}
	ln -sf "$exec_path" "$SCRIPTS_BIN_PATH/$appname"
	log "App '$appname' installed successfully." "SUCCESS"
	return 0
}

install_app() {
	local appname="$1"
	local force="${2:-false}"
	local version="${APP_VERSIONS[$appname]}"
	local url="${APP_URLS[$appname]}"
	local exec_name="${APP_EXECUTABLE_NAME[$appname]}"
	local install_dir="$APPS_INSTALL_PATH/$appname-$version"
	local pkg_path="$PACKAGES_PATH/apps/$(basename "$url")"
	local symlink_path="$SCRIPTS_BIN_PATH/$exec_name"

	log "--- Installing App: $appname $version ---" "INFO"
	if [[ -L "$symlink_path" && "$force" == "false" ]]; then
		log "$appname already installed. Skipping." "INFO"
		return 0
	fi
	if [[ "$force" == "true" ]]; then
		log "Force reinstall for $appname." "WARN"
		rm -rf "$install_dir" "$symlink_path"
	fi
	rm -rf "$install_dir"

	mkdir -p "$install_dir"
	download_package "$url" "$pkg_path"
	extract_package "$pkg_path" "$install_dir" 0

	# Dynamically determine the executable name if set to "special"
	if declare -F "_install_$appname" >/dev/null; then
		log "Using dedicated install function for $appname." "DEBUG"
		"_install_$appname" "$appname" "$install_dir"
	else
		log "Using default install function for $appname." "DEBUG"
		_install_default "$exec_name" "$install_dir"
	fi || return 1 # Exit if install function fails
	log "$appname installation complete." "SUCCESS"
}

###############################################################################
# Post-Install & Packaging
###############################################################################
configure() {
	local target="$1"
	case "$target" in
	"tmux")
		log "Configuring tmux..."
		local cfg_dir="$CONFIG_PATH/tmux"
		mkdir -p "$cfg_dir"
		if [[ ! -d "$cfg_dir/.tmux" ]]; then git clone --depth 1 "https://github.com/gpakosz/.tmux.git" "$cfg_dir/.tmux"; fi
		ln -sf "$cfg_dir/.tmux/.tmux.conf" "$HOME/.tmux.conf"
		# Copy local config only if it doesn't exist, to prevent overwriting user changes
		cp -n "$cfg_dir/.tmux/.tmux.conf.local" "$HOME/.tmux.conf.local"
		;;
	"zsh")
		log "Configuring Zsh..."
		local cfg_dir="$CONFIG_PATH/zsh"
		mkdir -p "$cfg_dir"
		if [[ ! -d "$cfg_dir/.oh-my-zsh" ]]; then
			git clone --depth 1 "https://github.com/ohmyzsh/ohmyzsh.git" "$cfg_dir/.oh-my-zsh"
			git clone --depth 1 https://github.com/romkatv/powerlevel10k.git "$cfg_dir/.oh-my-zsh/custom/themes/powerlevel10k"
			git clone --depth 1 https://github.com/zsh-users/zsh-autosuggestions.git "$cfg_dir/.oh-my-zsh/custom/plugins/zsh-autosuggestions"
			git clone --depth 1 https://github.com/zsh-users/zsh-syntax-highlighting.git "$cfg_dir/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting"
		fi
		if [[ ! -L "$HOME/.oh-my-zsh" ]]; then
			ln -sf "$cfg_dir/.oh-my-zsh" "$HOME/.oh-my-zsh"
		fi
		# Only create a .zshrc if one does not exist
		if [[ ! -f "$HOME/.zshrc" ]]; then
			cp "$cfg_dir/.oh-my-zsh/templates/zshrc.zsh-template" "$HOME/.zshrc"
			sed -i 's|ZSH_THEME="robbyrussell"|ZSH_THEME="powerlevel10k/powerlevel10k"|g' "$HOME/.zshrc"
			sed -i 's|plugins=(git)|plugins=(git autojump zsh-autosuggestions zsh-syntax-highlighting)|g' "$HOME/.zshrc"
		fi
		# Ensure OMW environment is sourced in .zshrc
		if ! grep -q "OMW_HOME" "$HOME/.zshrc"; then
			echo -e '\n# OMW Config\nexport OMW_HOME="'$OMW_HOME'"\n[[ -f "$OMW_HOME/env.sh" ]] && source "$OMW_HOME/env.sh"' >>"$HOME/.zshrc"
		fi
		# Add a hook for user customizations if it doesn't exist
		if ! grep -q ".zshrc_custom" "$HOME/.zshrc"; then
			echo -e '\n# User customizations file\n[[ -f "$HOME/.zshrc_custom" ]] && source "$HOME/.zshrc_custom"' >>"$HOME/.zshrc"
		fi
		# Create the custom file if it's missing
		if [[ ! -f "$HOME/.zshrc_custom" ]]; then
			cat >"$HOME/.zshrc_custom" <<-EOF
				# Add your custom Zsh configurations here
				# For example, set your preferred editor:
				# export EDITOR='nvim'
			EOF
		fi
		;;
	*)
		log "Unknown config target: $target" "ERROR"
		;;
	esac
	log "$target configuration complete." "SUCCESS"
}

# MODIFIED: Creates offline bundle by downloading all defined versions of all software
create_offline_bundle() {
	log "--- Creating OMW Offline Bundle ---" "INFO"
	# 1. Download all required assets
	log "Step 1: Downloading all software and app packages..."
	for app in "${SOFTWARE_LIST[@]}"; do
		local versions_str="${SOFTWARE_VERSIONS[$app]}"
		[[ -z "$versions_str" ]] && continue
		for version in $versions_str; do
			local url
			url=$(_get_software_url "$app" "$version")
			[[ -n "$url" ]] && download_package "$url" "$PACKAGES_PATH/software/$(basename "$url")"
		done
	done
	for app in "${APP_LIST[@]}"; do download_package "${APP_URLS[$app]}" "$PACKAGES_PATH/apps/$(basename "${APP_URLS[$app]}")"; done

	prefetch_gcc_prereqs

	log "Step 2: Preparing local dependencies (RPMs)..."
	build_local "false" "false" "${SOFTWARE_VERSIONS[local]}" # Run build_local for its download side-effect
	if [[ -d "$BUILDS_PATH/local-rpms" ]] && [[ ! -f "$PACKAGES_PATH/rpms.tar.gz" ]]; then
		tar -czf "$PACKAGES_PATH/rpms.tar.gz" -C "$BUILDS_PATH/local-rpms" .
	fi

	log "Step 3: Preparing configurations (git repos)..."
	configure "tmux"
	configure "zsh"

	# 3.1 Generate checksums for all packages
	write_checksums

	# 3.2 Verify offline completeness before packing
	log "Step 4: Verifying offline completeness..."
	if ! verify_offline; then
		log "Offline verification failed. Please fix missing items before packing." "ERROR"
		return 1
	fi

	# 4. Create the final archive
	local archive_name="omw-offline-bundle-$(date +%Y%m%d).tar.gz"
	log "Step 5: Creating final archive: $archive_name"
	cd "$OMW_HOME"
	# Exclude directories that are generated on the target machine
	tar --exclude="*.git" --exclude="./builds" --exclude="./bin" --exclude="./tools" --exclude="./apps" \
		-czf "$HOME/$archive_name" .
	log "Offline bundle created successfully!" "SUCCESS"
	log "To use, transfer '$HOME/$archive_name' to an offline machine, extract it, and run './omw --all'" "INFO"
}

###############################################################################
# Main Execution
###############################################################################
main() {
	init_globals
	check_sys_deps
	[[ $# -eq 0 ]] && {
		main --help
		exit 0
	}

	# Advanced argument parsing
	local command=""
	local target=""
	local force=false
	local refresh=false

	while [[ $# -gt 0 ]]; do
		case "$1" in
		-a | --all | -b | --build | -i | --install | --install-all-apps | -c | --config | --clean | -p | --pack | --verify-offline)
			[[ -n "$command" ]] && {
				log "Only one command can be specified at a time." "ERROR"
				exit 1
			}
			command="$1"
			shift
			# These commands do not take a target argument
			if [[ "$command" != "--install-all-apps" && "$command" != "-p" && "$command" != "--pack" && "$command" != "-a" && "$command" != "--all" && "$command" != "--verify-offline" ]]; then
				target="$1"
				shift
			fi
			;;
		--force)
			force=true
			shift
			;;
		--refresh)
			refresh=true
			shift
			;;
		-h | --help)
			command="$1"
			shift
			;;
		*)
			log "Invalid option or command: $1" "ERROR"
			main --help
			exit 1
			;;
		esac
	done

	# Command execution
	case "$command" in
	-a | --all)
		# Loop through all software and all their defined versions
		for sw in "${SOFTWARE_LIST[@]}"; do
			local versions_str="${SOFTWARE_VERSIONS[$sw]}"
			[[ -z "$versions_str" ]] && continue
			for version in $versions_str; do
				build_software "$sw@$version" "$force" "$refresh"
			done
		done
		for app in "${APP_LIST[@]}"; do install_app "$app" "$force"; done
		configure "tmux"
		configure "zsh"
		;;
	-b | --build)
		[[ -z "$target" ]] && {
			log "Build command requires a software target, e.g., 'vim' or 'python@3.9.18'." "ERROR"
			exit 1
		}
		local appname version
		read -r appname version < <(_parse_target "$target")
		# If no version is specified, build all available versions for that app
		if [[ -z "$version" ]]; then
			log "No version specified for '$appname'. Building all defined versions." "INFO"
			local versions_str="${SOFTWARE_VERSIONS[$appname]}"
			if [[ -z "$versions_str" ]]; then
				log "No versions defined for '$appname' in software.conf." "ERROR"
				exit 1
			fi
			for v in $versions_str; do
				build_software "$appname@$v" "$force" "$refresh"
			done
		else
			# Build the specific version requested
			build_software "$target" "$force" "$refresh"
		fi
		;;
	-i | --install)
		[[ -z "$target" ]] && {
			log "Install command requires an app target." "ERROR"
			exit 1
		}
		install_app "$target" "$force"
		;;
	--install-all-apps)
		for app in "${APP_LIST[@]}"; do install_app "$app" "$force"; done
		;;
	-c | --config)
		[[ -z "$target" ]] && {
			log "Config command requires a target ('tmux' or 'zsh')." "ERROR"
			exit 1
		}
		configure "$target"
		;;
	--clean)
		log "Cleaning ${target#--}..."
		case "${target#--}" in
		"builds") rm -rf "$BUILDS_PATH" ;;
		"packages") rm -rf "$PACKAGES_PATH" ;;
		"installs") rm -rf "$SOFTWARE_INSTALL_PATH" "$MODULEFILES_PATH" ;;
		"apps") rm -rf "$APPS_INSTALL_PATH" "$SCRIPTS_BIN_PATH"/* ;;
		"all") rm -rf "$BUILDS_PATH" "$PACKAGES_PATH" "$OMW_HOME/tools" "$APPS_INSTALL_PATH" "$SCRIPTS_BIN_PATH"/* ;;
		*)
			log "Invalid clean target. Use: builds, packages, installs, apps, all." "ERROR"
			exit 1
			;;
		esac
		log "Clean complete." "SUCCESS"
		;;
	-p | --pack)
		create_offline_bundle
		;;
	--verify-offline)
		if verify_offline; then
			exit 0
		else
			exit 1
		fi
		;;
	-h | --help)
		cat <<-EOF
			Usage: $0 [command] <target> [options]
			OMW - A self-contained development environment manager.

			Commands:
			  -a, --all               Install all defined versions of all software, all apps, and apply configurations.
			  -b, --build <target>    Build specific software. Target can be 'name' (builds all versions)
			                          or 'name@version' (builds a specific version).
			  -i, --install <app>     Install a specific pre-compiled app (e.g., eza).
			  --install-all-apps      Install all pre-compiled apps.
			  -c, --config <target>   Configure a specific tool ('tmux' or 'zsh').
			  --clean <target>        Clean directories. Targets: builds, packages, installs, apps, all.
			  -p, --pack              Create a comprehensive offline deployment bundle with all versions.
			  --verify-offline        Verify all assets are present for a fully offline build.
			  -h, --help              Show this help message.

			Options for build/install:
			  --force                 Force re-installation (will backup existing).
			  --refresh               Only refresh the modulefile for a built software.

			Examples:
			  # Build all defined versions of vim
			  $0 --build vim

			  # Build a specific version of python, forcing a rebuild
			  $0 --build python@3.9.18 --force

			  # Install the eza command-line tool
			  $0 --install eza

			  # Create an offline bundle for deployment on another machine
			  $0 --pack

			Software to build: ${SOFTWARE_LIST[*]}
			Apps to install: ${APP_LIST[*]}
		EOF
		;;
	*)
		log "No command specified." "WARN"
		main --help
		;;
	esac
}

main "$@"