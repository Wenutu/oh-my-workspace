###############################################################################
# Configuration Functions (tmux, zsh)
###############################################################################

config_tmux() {
    local version=${PERSONAL_SOFTWARE[tmux]}
    local config_dir="$CONFIG_PATH/tmux/tmux-$version"
    local repo_url="https://github.com/gpakosz/.tmux.git"
    local package_path="$PACKAGES_PATH/config/tmux-$version-config.tar.gz"

    log "###############################################################################"
    log "# Configuring tmux"
    log "###############################################################################"

    log "Starting tmux configuration..." "INFO"

    if [[ -f "$HOME/.tmux.conf" ]]; then
        log "Backing up existing ~/.tmux.conf to ~/.tmux.conf.bak" "WARN"
        mv "$HOME/.tmux.conf" "$HOME/.tmux.conf.bak"
    fi
    if [[ -d "$HOME/.tmux" ]]; then
        log "Backing up existing ~/.tmux directory to ~/.tmux.bak" "WARN"
        mv "$HOME/.tmux" "$HOME/.tmux.bak"
    fi

    if [[ ! -d "$config_dir" ]]; then
        mkdir -p "$config_dir"
    fi

    if [[ -d "$config_dir/.tmux" ]]; then
        log "Oh My Tmux configuration already exists in $config_dir/.tmux. Skipping clone." "INFO"
    elif [[ -f "$package_path" ]]; then
        log "Extracting tmux configuration from package: $package_path" "INFO"
        extract_package "$package_path" "$config_dir"
    else
        log "Cloning Oh My Tmux configuration from $repo_url to $config_dir/.tmux" "INFO"
        git clone --depth 1 "$repo_url" "$config_dir/.tmux"
    fi

    ln -sf "$config_dir/.tmux/.tmux.conf" "$HOME/.tmux.conf"
    ln -sf "$config_dir/.tmux/.tmux.conf.local" "$HOME/.tmux.conf.local"

    log "tmux configuration completed." "SUCCESS"
}

config_zsh() {
    local version=${PERSONAL_SOFTWARE[zsh]}
    local config_dir="$CONFIG_PATH/zsh/zsh-$version"
    local repo_url="https://github.com/ohmyzsh/ohmyzsh.git"
    local package_path="$PACKAGES_PATH/config/zsh-$version-config.tar.gz"

    log "###############################################################################"
    log "# Configuring Zsh"
    log "###############################################################################"

    log "Starting zsh configuration..." "INFO"

    if [[ -f "$HOME/.zshrc" ]]; then
        log "Backing up existing ~/.zshrc to ~/.zshrc.bak" "WARN"
        mv "$HOME/.zshrc" "$HOME/.zshrc.bak"
    fi
    if [[ -L "$HOME/.oh-my-zsh" ]]; then
        log "Removing existing symbolic link ~/.oh-my-zsh" "WARN"
        rm "$HOME/.oh-my-zsh"
    fi

    if [[ ! -d "$config_dir" ]]; then
        mkdir -p "$config_dir"
    fi

    if [[ -d "$config_dir/.oh-my-zsh" ]]; then
        log "Oh My Zsh configuration already exists in $config_dir/.oh-my-zsh. Skipping clone." "INFO"
    elif [[ -f "$package_path" ]]; then
        log "Extracting zsh configuration from package: $package_path" "INFO"
        extract_package "$package_path" "$config_dir"
    else
        log "Cloning Oh My Zsh configuration from $repo_url to $config_dir/.oh-my-zsh" "INFO"
        git clone --depth 1 "$repo_url" "$config_dir/.oh-my-zsh"

        log "Cloning Powerlevel10k theme and plugins..." "INFO"
        git clone --depth 1 https://github.com/romkatv/powerlevel10k.git "$config_dir/.oh-my-zsh/custom/themes/powerlevel10k"
        git clone --depth 1 https://github.com/zsh-users/zsh-autosuggestions "$config_dir/.oh-my-zsh/custom/plugins/zsh-autosuggestions"
        git clone --depth 1 https://github.com/zsh-users/zsh-syntax-highlighting "$config_dir/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting"
    fi

    ln -sf "$config_dir/.oh-my-zsh" "$HOME/.oh-my-zsh"
    cp "$config_dir/.oh-my-zsh/templates/zshrc.zsh-template" "$HOME/.zshrc"

    cat >> "$HOME/.zshrc" <<-EOF

# OMW (Oh My Workspace) Configuration - DO NOT REMOVE OR MODIFY
export OMW_HOME="$OMW_HOME"
export PATH="\$OMW_HOME/scripts/bin:\$PATH"
export MODULEPATH="\$OMW_HOME/tools/public/modulefiles:\$OMW_HOME/tools/personal/modulefiles:\$MODULEPATH"
export PUBLIC_SOFTWARE="\$OMW_HOME/public/software"
export PERSONAL_SOFTWARE="\$OMW_HOME/personal/software"
# End of OMW Configuration
EOF

    log "Zsh configuration completed." "SUCCESS"
}

###############################################################################
# Package Management Functions (Create Config Packages, Create RPMs Package, Create Packages Archive)
###############################################################################

create_config_packages() {
    log "###############################################################################"
    log "# Creating Configuration Packages"
    log "###############################################################################"

    if [[ ! -d "$PACKAGES_PATH/config" ]]; then
        mkdir -p "$PACKAGES_PATH/config"
    fi

    log "Creating tmux configuration package..." "INFO"
    if [[ ! -d "$CONFIG_PATH/tmux/tmux-${PERSONAL_SOFTWARE[tmux]}" ]]; then
        log "No tmux configuration found in $CONFIG_PATH/tmux/tmux-${PERSONAL_SOFTWARE[tmux]}. Skipping tmux configuration package creation." "WARN"
    else
        tar -czf "$PACKAGES_PATH/config/tmux-${PERSONAL_SOFTWARE[tmux]}-config.tar.gz" -C "$CONFIG_PATH/tmux" "tmux-${PERSONAL_SOFTWARE[tmux]}"
        log "tmux configuration package created successfully: $PACKAGES_PATH/config/tmux-${PERSONAL_SOFTWARE[tmux]}-config.tar.gz" "SUCCESS"
    fi

    log "Creating Zsh configuration package..." "INFO"
    if [[ ! -d "$CONFIG_PATH/zsh/zsh-${PERSONAL_SOFTWARE[zsh]}" ]]; then
        log "No Zsh configuration found in $CONFIG_PATH/zsh/zsh-${PERSONAL_SOFTWARE[zsh]}. Skipping Zsh configuration package creation." "WARN"
    else
        tar -czf "$PACKAGES_PATH/config/zsh-${PERSONAL_SOFTWARE[zsh]}-config.tar.gz" -C "$CONFIG_PATH/zsh" "zsh-${PERSONAL_SOFTWARE[zsh]}"
        log "Zsh configuration package created successfully: $PACKAGES_PATH/config/zsh-${PERSONAL_SOFTWARE[zsh]}-config.tar.gz" "SUCCESS"
    fi

    log "Configuration packages created successfully in $PACKAGES_PATH/config." "SUCCESS"
}

create_rpms_package() {
    log "Creating rpms package..." "INFO"
    if [[ ! -d "$PUBLIC_SOFTWARE_PATH/local/build" ]] || [[ -z "$(ls -A $PUBLIC_SOFTWARE_PATH/local/build/*.rpm 2>/dev/null)" ]]; then
        log "No RPM packages found in $PUBLIC_SOFTWARE_PATH/local/build. Skipping RPM package creation." "WARN"
        return 1
    fi
    tar -czf "$PACKAGES_PATH/rpms.tar.gz" -C "$PUBLIC_SOFTWARE_PATH/local/build" .
    log "RPM package created successfully: $PACKAGES_PATH/rpms.tar.gz" "SUCCESS"
}

create_packages_archive() {
    timestamp=$(date +%Y-%m-%d-%H-%M-%S)
    packages_archive="$OMW_HOME/packages-${timestamp}.tar.gz"
    log "Creating archive of packages directory: $packages_archive" "INFO"
    tar -czf "$packages_archive" -C "$OMW_HOME" "packages"
    log "Packages directory archived successfully to: $packages_archive" "SUCCESS"
}

###############################################################################
# Main Execution Function and Argument Parsing
###############################################################################

main() {
    init_globals
    check_dependencies

    while [[ $# -gt 0 ]]; do
        local force_build=false
        local refresh_module=false
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: $0 [OPTIONS]

Options:
  -h, --help        Show this help message
  -a, --all         Install all software and configurations
  -b, --build [SOFTWARE]  Build specific software
      --force       Force rebuild existing installations (backup old installation)
      --refresh     Refresh modulefile only (skips build)
  -c, --config [SOFTWARE] Configure specific software
  --clean           Clean build directories (removes 'build' directories)
  -p, --pack        Create configuration packages (tmux, zsh, rpms, packages archive)

OWM Configuration Directories:
  OMW_HOME: $OMW_HOME
  CONFIG_PATH: $CONFIG_PATH
  PACKAGES_PATH: $PACKAGES_PATH
  PUBLIC_SOFTWARE_PATH: $PUBLIC_SOFTWARE_PATH
  PERSONAL_SOFTWARE_PATH: $PERSONAL_SOFTWARE_PATH

Available software for build (-b/--build):
  Public: ${!PUBLIC_SOFTWARE[*]} (except 'local')
  Personal: ${!PERSONAL_SOFTWARE[*]}

Available software for config (-c/--config):
  Config: tmux zsh
EOF
                exit 0
                ;;
            -a|--all)
                log "Option '--all' selected: Installing all software and configurations." "INFO"
                build_openssl
                build_libevent
                build_ncurses
                build_lua
                build_local
                build_python
                build_tmux
                build_zsh
                build_vim
                #config_tmux
                #config_zsh
                exit 0
                ;;
            -b|--build)
                shift
                local software="$1"
                shift
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --force)
                            force_build=true
                            shift
                            ;;
                        --refresh)
                            refresh_module=true
                            shift
                            ;;
                        *)
                            break
                            ;;
                    esac
                done
                log "Option '--build $software' selected. Force: $force_build, Refresh Module: $refresh_module" "INFO"
                case "$software" in
                    openssl|libevent|ncurses|lua|local|gcc|python|tmux|zsh|vim)
                        build_"$software" "$force_build" "$refresh_module"
                        ;;
                    *)
                        log "Unknown software: $software. Available options are: ${!PUBLIC_SOFTWARE[*]} ${!PERSONAL_SOFTWARE[*]}" "ERROR"
                        exit 1
                        ;;
                esac
                ;;
            -c|--config)
                shift
                local config_software="$1"
                shift
                log "Option '--config $config_software' selected." "INFO"
                case "$config_software" in
                    tmux) config_tmux ;;
                    zsh) config_zsh ;;
                    *) log "Unknown configuration: $config_software. Available options are: tmux zsh" "ERROR"; exit 1 ;;
                esac
                ;;
            --clean)
                log "Option '--clean' selected: Cleaning build directories." "INFO"
                clean
                exit 0
                ;;
            -p|--pack)
                log "Option '--pack' selected: Creating configuration and packages archives." "INFO"
                create_rpms_package
                create_config_packages
                create_packages_archive
                exit 0
                ;;
            *)
                log "Invalid option: $1. Use -h or --help for usage instructions." "ERROR"
                exit 1
                ;;
        esac
        shift
    done

    if [[ $# -eq 0 ]]; then
        log "No options provided. Showing help message. Use -h or --help for options." "WARN"
        main -h
    fi
}

main "$@"