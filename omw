    PERSONAL_SOFTWARE["vim"]="9.1.1176"

    #log "Personal software: ${!PERSONAL_SOFTWARE[*]}" "DEBUG"

    # Build configuration
    readonly BUILD_JOBS=$(( $(nproc) > 2 ? $(nproc)-2 : 1 ))
    readonly MAX_RETRIES=3
    readonly DOWNLOAD_TIMEOUT=300  # 5 minutes
}

###############################################################################
# Utility Functions
###############################################################################

# Logging function with colors and timestamps
log() {
    local msg=$1
    local level=${2:-INFO}
    local timestamp=$(date +"%Y-%m-%d %T")

    declare -A levels=(
        ["DEBUG"]="34"    # Blue
        ["INFO"]="36"     # Cyan
        ["WARN"]="33"     # Yellow
        ["ERROR"]="31"    # Red
        ["SUCCESS"]="32"  # Green
    )

    local color_code=${levels[$level]:-36}
    echo -e "\033[1;${color_code}m[${level}] ${timestamp} - ${msg}\033[0m" >&2
}

# Spinner function (simple waiting animation)
spinner() {
    local delay=0.1
    local spin_chars="-\|/"
    local count=0
    while :; do
        local char=$(printf "%s" "$spin_chars" | cut -c $((count % ${#spin_chars} + 1)))
        echo -ne "\r\033[1;36m[INFO] $(date +'%Y-%m-%d %T') - Processing ${char}" >&2
        sleep "$delay"
        count=$((count + 1))
    done
    echo -ne "\033[0m" >&2
}

# Stop spinner and clear line
stop_spinner() {
    echo -ne "\r\033[K" >&2
}

# Check for required system commands
check_dependencies() {
    local required_commands=(
        "wget" "tar" "make" "git" "rpm2cpio"
        "cpio" "sed" "find" "nproc"
        "yumdownloader" # Required for local package
    )

    for cmd in "${required_commands[@]}"; do
        if ! command -v "$cmd" &> /dev/null; then
            log "Missing required command: $cmd" "ERROR"
            exit 1
        fi
    done
}

# Robust package download with retries and timeout
download_package() {
    local url=$1
    local dest=$2
    local retries=${3:-$MAX_RETRIES}

    log "Downloading package from $url" "INFO"
    # check dest
    if [[ -f "$dest" ]]; then
        log "Package already downloaded: $dest" "INFO"
        return 0
    fi

    mkdir -p "$(dirname "$dest")"
    for ((i=1; i<=retries; i++)); do
        if wget --tries=3 --timeout=$DOWNLOAD_TIMEOUT -O "$dest" "$url" &> /dev/null; then
            log "Download completed successfully" "SUCCESS"
            return 0
        fi
        log "Download attempt $i failed, retrying..." "WARN"
        sleep $((i*2))
    done

    log "Failed to download $url after $retries attempts" "ERROR"
    return 1
}

# Safe package extraction with validation
extract_package() {
    local package=$1
    local dest=$2
    local strip=${3:-1}

    log "Extracting $package to $dest" "INFO"

    if [[ ! -f "$package" ]]; then
        log "Package file not found: $package" "ERROR"
        return 1
    fi

    mkdir -p "$dest"

    # check package format
    if [[ "$package" == *.tar.gz ]]; then
        extract_cmd="tar -xzf"
    elif [[ "$package" == *.tar.xz ]]; then
        extract_cmd="tar -xJf"
    elif [[ "$package" == *.tar.bz2 ]]; then
        extract_cmd="tar -xjf"
    elif [[ "$package" == *.zip ]]; then
        extract_cmd="unzip"
    elif [[ "$package" == *.tgz ]]; then
        extract_cmd="tar -xzf"
    else
        log "Unsupported package format: $package" "ERROR"
        return 1
    fi
    $extract_cmd "$package" -C "$dest" --strip-components=$strip &> /dev/null
    # Verify extraction results
    if [[ -z "$(ls -A "$dest")" ]]; then
        log "Extracted directory is empty: $dest" "ERROR"
        return 1
    fi
}

# Execute configure, make and make install with logging and spinner
execute_build_steps() {
    local build_dir=$1
    local configure_cmd=$2
    local build_jobs=$3
    local prefix=$4

    log "Configuring in $build_dir" "INFO"
    local configure_status=0
    (
        cd "$build_dir"
        spinner &
        spinner_pid=$!
        #log "pid: $spinner_pid" "DEBUG"
        #log "Running: $configure_cmd" "DEBUG"
        $configure_cmd > omw_configure.log 2>&1
        configure_status=$? # Capture exit status of configure_cmd
        kill "$spinner_pid" 2>/dev/null
        stop_spinner
    )
    if [[ "$configure_status" -ne 0 ]]; then
        log "Configure failed. Check configure.log in $build_dir" "ERROR"
        return 1
    fi
    log "Configure completed successfully" "SUCCESS"

    log "Building with make -j $build_jobs in $build_dir" "INFO"
    local make_status=0
    (
        cd "$build_dir"
        spinner &
        spinner_pid=$!
        make -j "$build_jobs" &> omw_make.log
        make_status=$? # Capture exit status of make
        kill "$spinner_pid" 2>/dev/null
        stop_spinner
    )
    if [[ "$make_status" -ne 0 ]]; then
        log "make failed. Check make.log in $build_dir" "ERROR"
        return 1
    fi
    log "Make completed successfully" "SUCCESS"

    log "Installing with make install to $prefix" "INFO"
    local install_status=0
    (
        cd "$build_dir"
        spinner &
        spinner_pid=$!
        make install &>> omw_make.log
        install_status=$? # Capture exit status of make install
        kill "$spinner_pid" 2>/dev/null
        stop_spinner
    )
    if [[ "$install_status" -ne 0 ]]; then
        log "make install failed. Check make.log in $build_dir" "ERROR"
        return 1
    fi
    log "Install completed successfully" "SUCCESS"

    return 0
}

###############################################################################
# Modulefile Management
###############################################################################

# Generate environment module files
write_modulefile() {
    local appname=$1
    local version=$2
    local type=$3
    local CFLAGS=${4:-}
    local LDFLAGS=${5:-}

    local module_dir="$OMW_HOME/tools/$type/modulefiles/$appname"
    local modulefile_path="$module_dir/$appname-$version"

    log "Generating modulefile: $modulefile_path" "INFO"

    mkdir -p "$module_dir" || {
        log "Failed to create module directory: $module_dir" "ERROR"
        return 1
    }

    # Template for modulefile
    cat > "$modulefile_path" <<-EOF
#%Module1.0
##
## $appname modulefile
##
proc ModulesHelp { } {
    puts stderr "Loads $appname $version into environment"
}

module-whatis "Loads $appname $version"

set base    \$env(OMW_HOME)/tools/$type/software
set name    $appname
set version $version
set prefix  \$base/\$name/\$name-\$version

prepend-path PATH               \$prefix/bin
prepend-path C_INCLUDE_PATH     \$prefix/include
prepend-path CPLUS_INCLUDE_PATH \$prefix/include
prepend-path LIBRARY_PATH       \$prefix/lib
prepend-path LD_LIBRARY_PATH    \$prefix/lib
prepend-path PKG_CONFIG_PATH    \$prefix/lib/pkgconfig
prepend-path MANPATH            \$prefix/share/man
EOF

    # Add custom flags if provided
    if [ -n "$CFLAGS" ] && [ -n "$LDFLAGS" ]; then
cat >> $modulefile_path <<-EOF
if {[info exists env(CFLAGS)]} {
    setenv CFLAGS "\$env(CFLAGS) $CFLAGS"
} else {
    setenv CFLAGS "$CFLAGS"
}
if {[info exists env(LDFLAGS)]} {
    setenv LDFLAGS "\$env(LDFLAGS) $LDFLAGS"
} else {
    setenv LDFLAGS "$LDFLAGS"
}
EOF
    fi
    echo "$modulefile_path"
    return 0
}

