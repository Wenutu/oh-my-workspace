#!/bin/bash
set -eo pipefail

declare spinner_pid

handle_sigint() {
    log "Interrupt signal (SIGINT) received. Exiting..." "WARN"
    stop_spinner
    sleep 0.01
    kill -s SIGINT "$spinner_pid" 2>/dev/null
    exit 130
}
trap 'handle_sigint' SIGINT

###############################################################################
# Global Configuration and Initialization
###############################################################################

init_globals() {
    log "###############################################################################"
    log "# Environment Initialization"
    log "###############################################################################"

    if [[ -z "$OMW_HOME" ]]; then
        OMW_HOME=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
    fi

    if [[ -f "$OMW_HOME/env.sh" ]]; then
        source "$OMW_HOME/env.sh"
        log "Sourced environment configuration from $OMW_HOME/env.sh" "INFO"
    fi

    log "OMW_HOME: $OMW_HOME" "DEBUG"
    log "PATH: $PATH" "DEBUG"
    log "MODULEPATH: $MODULEPATH" "DEBUG"

    CONFIG_PATH="$OMW_HOME/config"
    PACKAGES_PATH="$OMW_HOME/packages"
    PUBLIC_SOFTWARE_PATH="$OMW_HOME/tools/public/software"
    PERSONAL_SOFTWARE_PATH="$OMW_HOME/tools/personal/software"

    readonly DIRECTORIES=(
        "$CONFIG_PATH"
        "$PACKAGES_PATH"
        "$PUBLIC_SOFTWARE_PATH"
        "$PERSONAL_SOFTWARE_PATH"
    )

    create_directories

    declare -gA PUBLIC_SOFTWARE
    PUBLIC_SOFTWARE["openssl"]="1.1.1w"
    PUBLIC_SOFTWARE["libevent"]="2.1.12"
    PUBLIC_SOFTWARE["ncurses"]="6.5"
    PUBLIC_SOFTWARE["lua"]="5.4.7"
    PUBLIC_SOFTWARE["gcc"]="13.2.0"
    PUBLIC_SOFTWARE["local"]="1.0.0"

    declare -gA PERSONAL_SOFTWARE
    PERSONAL_SOFTWARE["python"]="3.9.21"
    PERSONAL_SOFTWARE["tmux"]="3.5a"
    PERSONAL_SOFTWARE["zsh"]="5.9"
    PERSONAL_SOFTWARE["vim"]="9.1.1176"

    readonly BUILD_JOBS=$(( $(nproc) > 2 ? $(nproc)-2 : 1 ))
    readonly MAX_RETRIES=3
    readonly DOWNLOAD_TIMEOUT=300

    log "Initialization complete." "INFO"
}

create_directories() {
    log "Ensuring required directories exist..." "DEBUG"
    for dir in "${DIRECTORIES[@]}"; do
        if [[ ! -d "$dir" ]]; then
            mkdir -p "$dir"
            log "Created directory: $dir" "INFO"
        fi
    done
    log "Directory check and creation complete." "DEBUG"
}

###############################################################################
# Utility Functions (Logging, Spinner, Dependencies, Download, Extract)
###############################################################################

log() {
    local msg="$1"
    local level="${2:-INFO}"
    local timestamp=$(date +"%Y-%m-%d %T")

    declare -A levels=(
        ["DEBUG"]="34"
        ["INFO"]="36"
        ["WARN"]="33"
        ["ERROR"]="31"
        ["SUCCESS"]="32"
    )

    local color_code=${levels[$level]:-36}
    echo -e "\033[1;${color_code}m[${level}] ${timestamp} - ${msg}\033[0m" >&2
}

spinner() {
    local delay=0.1
    local spin_chars="-\|/"
    local count=0
    while :; do
        local char=$(printf "%s" "$spin_chars" | cut -c $((count % ${#spin_chars} + 1)))
        echo -ne "\r\033[1;36m[INFO] $(date +'%Y-%m-%d %T') - Processing ${char}" >&2
        sleep "$delay"
        count=$((count + 1))
    done
    echo -ne "\033[0m" >&2
}

stop_spinner() {
    echo -ne "\r\033[K\r\033[K\r\033[K" >&2 # Send clear command multiple times
}

check_dependencies() {
    log "Checking system dependencies..." "INFO"
    local required_commands=(
        "wget" "tar" "make" "git" "rpm2cpio"
        "cpio" "sed" "find" "nproc"
        "yumdownloader"
    )

    for cmd in "${required_commands[@]}"; do
        if ! command -v "$cmd" &> /dev/null; then
            log "Missing required command: $cmd. Please install it." "ERROR"
            exit 1
        fi
        #log "Dependency '$cmd' is available." "DEBUG"
    done
    log "All system dependencies are satisfied." "SUCCESS"
}

download_package() {
    local url="$1"
    local dest="$2"
    local retries=${3:-$MAX_RETRIES}

    log "Downloading package from $url to $dest" "INFO"

    if [[ -f "$dest" ]]; then
        log "Package already exists at $dest. Skipping download." "INFO"
        return 0
    fi

    mkdir -p "$(dirname "$dest")"

    for ((i=1; i<=retries; i++)); do
        log "Download attempt $i/$retries..." "DEBUG"
        if wget --tries=3 --timeout="$DOWNLOAD_TIMEOUT" -O "$dest" "$url" &> /dev/null; then
            log "Download successful to $dest." "SUCCESS"
            return 0
        fi
        log "Download attempt $i failed. Retrying in $((i*2)) seconds..." "WARN"
        sleep $((i*2))
    done

    log "Failed to download $url after $retries attempts." "ERROR"
    return 1
}

extract_package() {
    local package="$1"
    local dest="$2"
    local strip=${3:-1}

    log "Extracting package $package to $dest" "INFO"

    if [[ ! -f "$package" ]]; then
        log "Package file not found: $package" "ERROR"
        return 1
    fi
    if [[ ! -d "$dest" ]]; then
        mkdir -p "$dest"
    fi

    case "$package" in
        *.tar.gz|*.tgz) extract_cmd="tar -xzf";;
        *.tar.xz)      extract_cmd="tar -xJf";;
        *.tar.bz2)     extract_cmd="tar -xjf";;
        *.zip)         extract_cmd="unzip";;
        *)             log "Unsupported package format: $package" "ERROR"; return 1;;
    esac

    log "Using command '$extract_cmd' for extraction." "DEBUG"
    log "Command: $extract_cmd $package -C $dest --strip-components=$strip" "DEBUG"
    $extract_cmd "$package" -C "$dest" --strip-components="$strip"
    sleep 5
    if [[ -z "$(ls -A "$dest")" ]]; then
        log "Extraction failed: Destination directory $dest is empty." "ERROR"
        return 1
    fi
    log "Package extracted successfully to $dest." "SUCCESS"
}

###############################################################################
# Build Process Functions (Configure, Make, Install)
###############################################################################

execute_build_steps() {
    local build_dir="$1"
    local configure_cmd="$2"
    local build_jobs="$3"
    local prefix="$4"

    log "Starting configuration in $build_dir" "INFO"
    log "LDFLAGS: $LDFLAGS" "DEBUG"
    log "CFLAGS: $CFLAGS" "DEBUG"
    local configure_status=0
    (
        cd "$build_dir"
        spinner &
        spinner_pid=$!
        log "Executing configure command: $configure_cmd" "DEBUG"
        $configure_cmd > omw_configure.log 2>&1
        configure_status=$?
        kill "$spinner_pid" 2>/dev/null
        stop_spinner
        tail -n 10 "$build_dir/omw_configure.log" 2>&1 & # tail log in background
    )
    wait # wait for tail to finish before check configure_status

    if [[ "$configure_status" -ne 0 ]]; then
        log "Configure failed. Check omw_configure.log in $build_dir for details." "ERROR"
        return 1
    fi
    log "Configuration completed successfully." "SUCCESS"

    log "Starting build with 'make -j $build_jobs' in $build_dir" "INFO"
    local make_status=0
    (
        cd "$build_dir"
        spinner &
        spinner_pid=$!
        log "Executing make command: make -j $build_jobs" "DEBUG"
        make -j "$build_jobs" &> omw_make.log
        make_status=$?
        kill "$spinner_pid" 2>/dev/null
        stop_spinner
        tail -n 10 "$build_dir/omw_make.log" 2>&1 & # tail log in background
    )
    wait # wait for tail to finish before check make_status
    if [[ "$make_status" -ne 0 ]]; then
        log "Make failed. Check omw_make.log in $build_dir for details." "ERROR"
        return 1
    fi
    log "Make completed successfully." "SUCCESS"

    log "Starting installation with 'make install' to $prefix" "INFO"
    local install_status=0
    (
        cd "$build_dir"
        spinner &
        spinner_pid=$!
        log "Executing install command: make install" "DEBUG"
        make install &>> omw_make.log
        install_status=$?
        kill "$spinner_pid" 2>/dev/null
        stop_spinner
        tail -n 10 "$build_dir/omw_make.log" 2>&1 & # tail log in background
    )
    wait # wait for tail to finish before check install_status
    if [[ "$install_status" -ne 0 ]]; then
        log "Make install failed. Check omw_make.log in $build_dir for details." "ERROR"
        return 1
    fi
    log "Install completed successfully to $prefix." "SUCCESS"

    return 0
}

###############################################################################
# Modulefile Management Functions
###############################################################################

write_modulefile() {
    local appname="$1"
    local version="$2"
    local type="$3"
    local CFLAGS="${4:-}"
    local LDFLAGS="${5:-}"

    local module_dir="$OMW_HOME/tools/$type/modulefiles/$appname"
    local modulefile_path="$module_dir/$appname-$version"

    log "Generating modulefile: $modulefile_path" "INFO"

    mkdir -p "$module_dir" || {
        log "Failed to create module directory: $module_dir" "ERROR"
        return 1
    }

    cat > "$modulefile_path" <<-EOF
#%Module1.0
##
## Modulefile for $appname $version
##
proc ModulesHelp { } {
    puts stderr "Loads $appname version $version into the environment."
    puts stderr "Sets up PATH, CFLAGS, LDFLAGS, and library paths for $appname."
}

module-whatis "Software: $appname $version"
module-whatis "Category: $type software"

set base    \$env(OMW_HOME)/tools/$type/software
set name    $appname
set version $version
set prefix  \$base/\$name/\$name-\$version

prepend-path PATH               \$prefix/bin
prepend-path C_INCLUDE_PATH     \$prefix/include
prepend-path CPLUS_INCLUDE_PATH \$prefix/include
prepend-path LIBRARY_PATH       \$prefix/lib
prepend-path LD_LIBRARY_PATH    \$prefix/lib
prepend-path PKG_CONFIG_PATH    \$prefix/lib/pkgconfig
prepend-path MANPATH            \$prefix/share/man
EOF

    if [ -n "$CFLAGS" ] && [ -n "$LDFLAGS" ]; then
        cat >> "$modulefile_path" <<-EOF

# Custom compiler flags
if {[info exists env(CFLAGS)]} {
    setenv CFLAGS "\$env(CFLAGS) $CFLAGS"
} else {
    setenv CFLAGS "$CFLAGS"
}
if {[info exists env(LDFLAGS)]} {
    setenv LDFLAGS "\$env(LDFLAGS) $LDFLAGS"
} else {
    setenv LDFLAGS "$LDFLAGS"
}
EOF
    fi
    log "Modulefile successfully written to $modulefile_path" "DEBUG"
    echo "$modulefile_path"
    return 0
}

###############################################################################
# Software Build Functions (OpenSSL, Libevent, Ncurses, Lua, Local, Python, Tmux, Zsh, Vim)
###############################################################################

clean() {
    log "###############################################################################"
    log "# Cleaning Build Directories"
    log "###############################################################################"

    log "Searching for 'build' directories to clean..." "INFO"
    find "$PUBLIC_SOFTWARE_PATH" "$PERSONAL_SOFTWARE_PATH" -name "build" -type d -print0 | while IFS= read -r -d $'\0' dir; do
        if [[ -d "$dir" ]]; then
            log "Removing build directory: $dir" "INFO"
            rm -rf "$dir"
        else
            log "Build directory not found (skipping): $dir" "DEBUG"
        fi
    done
    log "Cleaning process completed." "SUCCESS"
}

backup_existing_installation() {
    local install_prefix="$1"
    if [[ -d "$install_prefix" ]]; then
        timestamp=$(date +%Y-%m-%d-%H-%M-%S)
        backup_dir="${install_prefix}-backup-${timestamp}"
        log "Backing up existing installation from $install_prefix to $backup_dir" "WARN"
        mv "$install_prefix" "$backup_dir"
        log "Backup created at $backup_dir" "INFO"
    fi
}

build_openssl() {
    local force="${1:-false}"
    local refresh="${2:-false}"
    local version=${PUBLIC_SOFTWARE[openssl]}
    local prefix="$PUBLIC_SOFTWARE_PATH/openssl/openssl-$version"
    local pkg_url="https://www.openssl.org/source/openssl-$version.tar.gz"
    local pkg_path="$PACKAGES_PATH/software/openssl-$version.tar.gz"
    local build_dir="$PUBLIC_SOFTWARE_PATH/openssl/build"

    log "###############################################################################"
    log "# Building OpenSSL $version"
    log "###############################################################################"

    if [[ "$refresh" == "false" ]]; then
        if [[ "$force" == "true" ]]; then
            log "Force rebuild requested for OpenSSL $version." "WARN"
            backup_existing_installation "$prefix"
            rm -rf "$build_dir"
        elif [[ -d "$prefix" ]]; then
            log "OpenSSL $version already installed at $prefix. Skipping build. Use --force to rebuild." "INFO"
            return 0
        fi

        download_package "$pkg_url" "$pkg_path"
        extract_package "$pkg_path" "$build_dir"

        #local configure_command="./config --prefix=$prefix --openssldir=$prefix shared"
        local configure_command="./config --prefix=$prefix --openssldir=$prefix"

        if ! execute_build_steps "$build_dir" "$configure_command" "$BUILD_JOBS" "$prefix"; then
            return 1
        fi
    fi

    local modulefile_path=$(write_modulefile openssl "$version" public "-I\$prefix/include" "-L\$prefix/lib -lssl -lcrypto")
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created for OpenSSL $version: $modulefile_path" "INFO"
    else
        log "Failed to create modulefile for OpenSSL $version." "ERROR"
    fi
    log "OpenSSL $version installation completed." "SUCCESS"
}

build_libevent() {
    local force="${1:-false}"
    local refresh="${2:-false}"
    local version=${PUBLIC_SOFTWARE[libevent]}
    local prefix="$PUBLIC_SOFTWARE_PATH/libevent/libevent-$version"
    local pkg_url="https://github.com/libevent/libevent/releases/download/release-$version-stable/libevent-$version-stable.tar.gz"
    local pkg_path="$PACKAGES_PATH/software/libevent-$version-stable.tar.gz"
    local build_dir="$PUBLIC_SOFTWARE_PATH/libevent/build"

    log "###############################################################################"
    log "# Building Libevent $version"
    log "###############################################################################"

    if [[ "$refresh" == "false" ]]; then
        if [[ "$force" == "true" ]]; then
            log "Force rebuild requested for Libevent $version." "WARN"
            backup_existing_installation "$prefix"
            rm -rf "$build_dir"
        elif [[ -d "$prefix" ]]; then
            log "Libevent $version already installed at $prefix. Skipping build. Use --force to rebuild." "INFO"
            return 0
        fi

        download_package "$pkg_url" "$pkg_path"
        extract_package "$pkg_path" "$build_dir"

        build_openssl
        module load openssl/openssl-${PUBLIC_SOFTWARE[openssl]}

        local configure_command="./configure --prefix=$prefix --enable-shared"
        if ! execute_build_steps "$build_dir" "$configure_command" "$BUILD_JOBS" "$prefix"; then
            return 1
        fi
    fi

    local modulefile_path=$(write_modulefile libevent "$version" public)
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created for Libevent $version: $modulefile_path" "INFO"
        echo "module load openssl/openssl-${PUBLIC_SOFTWARE[openssl]}" >> "$modulefile_path"
    else
        log "Failed to create modulefile for Libevent $version." "ERROR"
    fi
    log "Libevent $version installation completed." "SUCCESS"
}

build_ncurses() {
    local force="${1:-false}"
    local refresh="${2:-false}"
    local version=${PUBLIC_SOFTWARE[ncurses]}
    local prefix="$PUBLIC_SOFTWARE_PATH/ncurses/ncurses-$version"
    local pkg_url="https://ftp.gnu.org/gnu/ncurses/ncurses-$version.tar.gz"
    local pkg_path="$PACKAGES_PATH/software/ncurses-$version.tar.gz"
    local build_dir="$PUBLIC_SOFTWARE_PATH/ncurses/build"

    log "###############################################################################"
    log "# Building Ncurses $version"
    log "###############################################################################"

    if [[ "$refresh" == "false" ]]; then
        if [[ "$force" == "true" ]]; then
            log "Force rebuild requested for Ncurses $version." "WARN"
            backup_existing_installation "$prefix"
            rm -rf "$build_dir"
        elif [[ -d "$prefix" ]]; then
            log "Ncurses $version already installed at $prefix. Skipping build. Use --force to rebuild." "INFO"
            return 0
        fi

        download_package "$pkg_url" "$pkg_path"
        extract_package "$pkg_path" "$build_dir"

        local configure_normal="./configure --prefix=$prefix --with-normal --disable-widec --with-shared --with-termlib --enable-pc-files --with-pkg-config-libdir=$prefix/lib/pkgconfig --enable-overwrite"
        local configure_widec="./configure --prefix=$prefix --with-normal --enable-widec --with-shared --with-termlib --enable-pc-files --with-pkg-config-libdir=$prefix/lib/pkgconfig --enable-overwrite"

        log "Configuring and building Ncurses $version (normal)..." "INFO"
        if ! execute_build_steps "$build_dir" "$configure_normal" "$BUILD_JOBS" "$prefix"; then
            return 1
        fi

        log "Configuring and building Ncurses $version (widec)..." "INFO"
        if ! execute_build_steps "$build_dir" "$configure_widec" "$BUILD_JOBS" "$prefix"; then
            return 1
        fi
    fi

    local modulefile_path=$(write_modulefile ncurses "$version" public "-I\$prefix/include" "-L\$prefix/lib -lncurses -lncursesw -ltinfo -ltinfow")
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created for Ncurses $version: $modulefile_path" "INFO"
    else
        log "Failed to create modulefile for Ncurses $version." "ERROR"
    fi
    log "Ncurses $version installation completed." "SUCCESS"
}

build_lua() {
    local force="${1:-false}"
    local refresh="${2:-false}"
    local version=${PUBLIC_SOFTWARE[lua]}
    local prefix="$PUBLIC_SOFTWARE_PATH/lua/lua-$version"
    local pkg_url="https://www.lua.org/ftp/lua-$version.tar.gz"
    local pkg_path="$PACKAGES_PATH/software/lua-$version.tar.gz"
    local build_dir="$PUBLIC_SOFTWARE_PATH/lua/build"

    log "###############################################################################"
    log "# Building Lua $version"
    log "###############################################################################"

    if [[ "$refresh" == "false" ]]; then
        if [[ "$force" == "true" ]]; then
            log "Force rebuild requested for Lua $version." "WARN"
            backup_existing_installation "$prefix"
            rm -rf "$build_dir"
        elif [[ -d "$prefix" ]]; then
            log "Lua $version already installed at $prefix. Skipping build. Use --force to rebuild." "INFO"
            return 0
        fi

        download_package "$pkg_url" "$pkg_path"
        extract_package "$pkg_path" "$build_dir"

        log "Building Lua $version using 'make linux'..." "INFO"
        (
            spinner &
            spinner_pid=$!
            cd "$build_dir"
            make linux INSTALL_TOP="$prefix" MYCFLAGS="-fPIC" MYLIBS="-Wl,-E" > make_config.log 2>&1
            make install INSTALL_TOP="$prefix" >> make_config.log 2>&1
            kill "$spinner_pid" 2>/dev/null
            stop_spinner
        )
    fi

    local modulefile_path=$(write_modulefile lua "$version" public)
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created for Lua $version: $modulefile_path" "INFO"
    else
        log "Failed to create modulefile for Lua $version." "ERROR"
    fi
    log "Lua $version installation completed." "SUCCESS"
}

build_local() {
    local force="${1:-false}"
    local refresh="${2:-false}"
    local version=${PUBLIC_SOFTWARE[local]}
    local prefix="$PUBLIC_SOFTWARE_PATH/local/local-$version"
    local build_dir="$PUBLIC_SOFTWARE_PATH/local/build"
    local package_path="$PACKAGES_PATH/rpms.tar.gz"

    log "###############################################################################"
    log "# Building local dependencies $version"
    log "###############################################################################"

    if [[ "$refresh" == "false" ]]; then
        if [[ "$force" == "true" ]]; then
            log "Force reinstall requested for local dependencies." "WARN"
            backup_existing_installation "$prefix"
            rm -rf "$build_dir"
        elif [[ -d "$prefix" ]]; then
            log "Local dependencies already installed at $prefix. Skipping install. Use --force to reinstall." "INFO"
            return 0
        fi

        if [[ ! -d "$build_dir" ]]; then
            mkdir -p "$build_dir"
        fi

        #if [[ ! -f "$package_path" ]] && [[ -z "$(ls -A $build_dir)" ]]; then
        if [[ ! -f "$package_path" ]] ; then
            log "Downloading system dependency RPMs..." "INFO"
            spinner &
            spinner_pid=$!
            yumdownloader --downloadonly --destdir="$build_dir" --resolve \
                gtk3-devel libX11-devel libXt-devel libSM-devel libICE-devel libXpm-devel xorg-x11-proto-devel \
                perl-ExtUtils-Embed \
                zlib-devel bzip2-devel libffi-devel sqlite-devel tkinter tcl-devel tk-devel \
                autoconf automake binutils bison flex gettext libtool patch pkgconfig > /dev/null
            kill "$spinner_pid" 2>/dev/null
            stop_spinner

            find "$build_dir" -name "*.i686.rpm" -delete
        else
            extract_package "$package_path" "$build_dir" 0
        fi

        mkdir -p "$prefix"
        cd "$prefix"
        log "Extracting RPM contents to $prefix..." "INFO"
        find "$build_dir" -maxdepth 1 -name "*.rpm" -print0 | while IFS= read -r -d $'\0' rpm_file; do
            rpm2cpio "$rpm_file" | cpio -idmv >> omw_cpio.log 2>&1
        done

        log "Fixing symbolic links in $prefix..." "INFO"
        find "$prefix" -type l | while read -r link; do
            target=$(readlink "$link")
            if [[ ! -e "$prefix/$target" ]]; then
                new_target="/lib64/$target"
                if [[ -e "$new_target" ]]; then
                    ln -sfn "$new_target" "$link"
                fi
            fi
        done

        log "Updating pkg-config file paths in $prefix..." "INFO"
        find "$prefix" -name "*.pc" | while read -r pcfile; do
            sed -i "s|=/usr|=$prefix/usr|g" "$pcfile"
            sed -i "s|-I/usr|-I$prefix/usr|g" "$pcfile"
            sed -i "s|-L/usr|-L$prefix/usr|g" "$pcfile"
        done
    fi

    local modulefile_path=$(write_modulefile local "$version" public "-I\$prefix/include -I/usr/include" "-L\$prefix/lib -L/usr/lib64")
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created for local dependencies: $modulefile_path" "INFO"
        sed -i "s|set prefix  \$base/\$name/\$name-\$version|set prefix  \$base/\$name/\$name-\$version/usr|g" "$modulefile_path"
        sed -i "s|\$prefix/lib|\$prefix/lib64|g" "$modulefile_path"
        echo "prepend-path PKG_CONFIG_PATH    \$prefix/share/pkgconfig" >> "$modulefile_path"
    else
        log "Failed to create modulefile for local dependencies." "ERROR"
    fi
    log "Local dependencies installation completed." "SUCCESS"
}

build_gcc() {
    local force="${1:-false}"
    local refresh="${2:-false}"
    local version=${PUBLIC_SOFTWARE[gcc]}
    local prefix="$PUBLIC_SOFTWARE_PATH/gcc/gcc-$version"
    local pkg_url="https://ftp.gnu.org/gnu/gcc/gcc-$version/gcc-$version.tar.gz"
    local pkg_path="$PACKAGES_PATH/software/gcc-$version.tar.gz"
    local build_dir="$PUBLIC_SOFTWARE_PATH/gcc/build"

    log "###############################################################################"
    log "# Building GCC $version"
    log "###############################################################################"

    if [[ "$refresh" == "false" ]]; then
        # If force=true, remove existing installation and build directory
        if [[ "$force" == "true" ]]; then
            log "Force rebuild requested for GCC $version." "WARN"
            backup_existing_installation "$prefix"
            rm -rf "$build_dir"
        # If GCC is already installed and force=false, skip the build
        elif [[ -d "$prefix" ]]; then
            log "GCC $version already installed at $prefix. Skipping build. Use --force to rebuild." "INFO"
            return 0
        fi

        # Download GCC source code
        download_package "$pkg_url" "$pkg_path"
        extract_package "$pkg_path" "$build_dir"

        # Define prerequisites (name and URL) -  From download_prerequisites.sh
        local base_url='http://gcc.gnu.org/pub/gcc/infrastructure/'
        local deps=(
            "gmp gmp-6.2.1.tar.bz2"
            "mpfr mpfr-4.1.0.tar.bz2"
            "mpc mpc-1.2.1.tar.gz"
            "isl isl-0.24.tar.bz2"
        )

        # Download, extract, and link dependencies
        log "Downloading and extracting GCC prerequisites..."
        for dep in "${deps[@]}"; do
            local dep_name=$(echo "$dep" | awk '{print $1}')     # Extract dependency name (e.g., gmp)
            local dep_archive=$(echo "$dep" | awk '{print $2}')  # Extract archive name (e.g., gmp-6.2.1.tar.bz2)
            local dep_url="${base_url}${dep_archive}"
            local dep_pkg="$PACKAGES_PATH/software/$dep_archive"
            local dep_dir_name="${dep_archive%.tar*}" # e.g., gmp-6.2.1

            # Check if dependency directory already exists and handle force
            local dep_install_dir="$build_dir/$dep_dir_name"
            if [[ "$force" == "true" ]]; then
                rm -rf "$dep_install_dir" # Remove existing dependency directory if force is true
            elif [[ -d "$dep_install_dir" ]]; then
                log "Dependency $dep_name already extracted. Skipping download and extraction." "INFO"
                continue # Skip to the next dependency if it exists and not forcing
            fi

            # Download the dependency
            download_package "$dep_url" "$dep_pkg"

            # Extract the dependency into the GCC build directory
            extract_package "$dep_pkg" "$build_dir" 0

            # Create a symbolic link for the dependency (like download_prerequisites.sh)
            local dep_link_target="$build_dir/$dep_dir_name" 
            local dep_link_name="$build_dir/$dep_name"
            if [[ "$force" == "true" ]]; then
                rm -f "$dep_link_name" # Remove existing symlink if force is true
            elif [[ -L "$dep_link_name" ]]; then
                log "Symlink for $dep_link_target already exists. Skipping symlink creation." "INFO"
                continue # Skip symlink creation if it exists and not forcing
            fi

            ln -sf "$dep_link_target" "$dep_link_name" || {
                log "Error creating symbolic link $dep_link_name -> $dep_link_target" "ERROR"
                return 1
            }
            log "Created symbolic link $dep_link_name -> $dep_link_target" "INFO"
        done
        log "GCC prerequisites downloaded and extracted."
        module load local/local-${PUBLIC_SOFTWARE[local]}
        # Configure and build GCC
        local configure_command="./configure --prefix=$prefix --disable-checking --enable-languages=c,c++,fortran --disable-multilib"
        if ! execute_build_steps "$build_dir" "$configure_command" "$BUILD_JOBS" "$prefix"; then
            return 1  # Return error if build fails
        fi
    fi

    # Generate modulefile for environment management
    local modulefile_path=$(write_modulefile gcc "$version" public)
    if [[ -f "$modulefile_path" ]]; then
        log "Modulefile created for GCC $version: $modulefile_path" "INFO"
    else
        log "Failed to create modulefile for GCC $version." "ERROR"
    fi
}

